---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Quinocycle — Wholesale Carton Box Supplier Malaysia',
  description = 'New and used carton boxes in bulk. Fixed wholesale prices. Min. order RM1,000. Delivery across Peninsular Malaysia.',
  ogImage = '/images/og-default.jpg',
} = Astro.props;

const WA_NUMBER = '60168916381'; // TODO: Replace with your WhatsApp number
const WA_LINK   = `https://wa.me/${WA_NUMBER}?text=Hi%20Quinocycle!%20I%20would%20like%20to%20enquire%20about%20your%20carton%20boxes.`;

const navLinks = [
  { href: '/shop',    label: 'Shop'    },
  { href: '/blog',    label: 'Blog'    },
  { href: '/about',   label: 'About'   },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#F5C400" />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Quinocycle" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- SEO -->
  <link rel="canonical" href={Astro.url.href} />

  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Quinocycle",
    "description": "Wholesale carton box supplier in Malaysia. New and used boxes in bulk.",
    "url": "https://www.quinocycle.com.my",
    "telephone": "+60168916381",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "MY"
    },
    "areaServed": "Peninsular Malaysia",
    "priceRange": "RM$$"
  }
  </script>
</head>

<body>
  <!-- NAV -->
  <header class="nav" id="nav">
    <div class="container nav__inner">
      <a href="/" class="nav__logo" aria-label="Quinocycle Home">
        <img src="/logo.png" alt="quinocycle" class="nav__logo-img" />
      </a>

      <nav class="nav__links hide-mobile" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav__link ${currentPath.startsWith(link.href) ? 'nav__link--active' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="nav__actions">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-sm hide-mobile nav__wa-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>

        <!-- Mobile hamburger -->
        <button class="nav__burger hide-desktop" id="navBurger" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Mobile drawer -->
    <div class="nav__mobile" id="navMobile" aria-hidden="true">
      {navLinks.map(link => (
        <a href={link.href} class="nav__mobile-link">{link.label}</a>
      ))}
      <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa" style="margin-top:1rem;">
        WhatsApp Us
      </a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer__top">
        <div class="footer__brand">
          <img src="/logo.png" alt="quinocycle" class="footer__logo" />
          <p class="footer__tagline">New &amp; used carton boxes in bulk.<br />Peninsular Malaysia delivery.</p>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-sm" style="margin-top:1.25rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Order
          </a>
        </div>

        <div class="footer__links">
          <div class="footer__col">
            <h4 class="footer__col-title">Quick Links</h4>
            <a href="/shop">Shop</a>
            <a href="/blog">Blog</a>
            <a href="/about">About Us</a>
            <a href="/contact">Contact</a>
          </div>
          <div class="footer__col">
            <h4 class="footer__col-title">Products</h4>
            <a href="/shop?filter=new">New Carton Boxes</a>
            <a href="/shop?filter=used">Used Carton Boxes</a>
            <a href="/shop?filter=small">Small Boxes</a>
            <a href="/shop?filter=large">Large Boxes</a>
          </div>
          <div class="footer__col">
            <h4 class="footer__col-title">Info</h4>
            <p>Min. Order: <strong>RM 1,000</strong></p>
            <p>Coverage: <strong>Peninsular Malaysia</strong></p>
            <p>Fixed wholesale pricing</p>
          </div>
        </div>
      </div>

      <div class="footer__bottom">
        <p class="footer__copy">&copy; {new Date().getFullYear()} Quinocycle. All rights reserved.</p>
        <div class="footer__legal">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- WhatsApp Float -->
  <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="wa-float" aria-label="Chat on WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script>
    // --- Sticky nav shadow ---
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('nav--scrolled', window.scrollY > 20);
    });

    // --- Mobile menu ---
    const burger = document.getElementById('navBurger');
    const mobile = document.getElementById('navMobile');
    burger?.addEventListener('click', () => {
      const open = mobile?.classList.toggle('nav__mobile--open');
      mobile?.setAttribute('aria-hidden', String(!open));
      burger?.classList.toggle('nav__burger--open');
    });

    // Close mobile menu on link click
    mobile?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobile.classList.remove('nav__mobile--open');
        mobile.setAttribute('aria-hidden', 'true');
        burger?.classList.remove('nav__burger--open');
      });
    });
  </script>
</body>
</html>

<style is:global>
/* NAV */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--white);
  border-bottom: 2px solid transparent;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.nav--scrolled {
  border-bottom-color: var(--yellow);
  box-shadow: 0 2px 24px rgba(0,0,0,0.07);
}
.nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--nav-h);
  gap: 2rem;
}
.nav__logo-img {
  height: 48px;
  width: auto;
}
.nav__links {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.nav__link {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--grey-600);
  transition: color 0.15s ease;
  position: relative;
}
.nav__link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--yellow);
  transition: width 0.2s ease;
}
.nav__link:hover, .nav__link--active {
  color: var(--black);
}
.nav__link:hover::after, .nav__link--active::after {
  width: 100%;
}
.nav__actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

/* Burger */
.nav__burger {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
}
.nav__burger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--black);
  transition: transform 0.2s ease, opacity 0.2s ease;
  transform-origin: center;
}
.nav__burger--open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.nav__burger--open span:nth-child(2) { opacity: 0; }
.nav__burger--open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* Mobile nav drawer */
.nav__mobile {
  display: none;
  flex-direction: column;
  padding: 1.5rem var(--pad-x) 2rem;
  background: var(--white);
  border-top: 1px solid var(--grey-200);
}
.nav__mobile--open { display: flex; }
.nav__mobile-link {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.5rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--grey-100);
  letter-spacing: 0.02em;
  color: var(--black);
}

/* FOOTER */
.footer {
  background: var(--black);
  color: var(--white);
  padding-top: clamp(3rem, 6vw, 5rem);
}
.footer__top {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 4rem;
  padding-bottom: clamp(2.5rem, 5vw, 4rem);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
@media (max-width: 768px) {
  .footer__top { grid-template-columns: 1fr; gap: 2.5rem; }
}
.footer__logo {
  height: 40px;
  width: auto;
  filter: invert(1) brightness(2);
  margin-bottom: 1rem;
}
.footer__tagline {
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--grey-400);
}
.footer__links {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
@media (max-width: 640px) {
  .footer__links { grid-template-columns: 1fr 1fr; }
}
.footer__col {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.footer__col a, .footer__col p {
  font-size: 0.875rem;
  color: var(--grey-400);
  transition: color 0.15s;
  line-height: 1.5;
}
.footer__col a:hover { color: var(--yellow); }
.footer__col strong { color: var(--white); }
.footer__col-title {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--grey-600);
  margin-bottom: 0.25rem;
}
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-block: 1.5rem;
  flex-wrap: wrap;
  gap: 1rem;
}
.footer__copy {
  font-size: 0.8rem;
  color: var(--grey-600);
}
.footer__legal {
  display: flex;
  gap: 1.5rem;
}
.footer__legal a {
  font-size: 0.8rem;
  color: var(--grey-600);
  transition: color 0.15s;
}
.footer__legal a:hover { color: var(--yellow); }
</style>

---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  heroMode?: boolean;
}

const {
  title = 'Quinocycle — Wholesale Carton Box Supplier Malaysia',
  description = 'New and used carton boxes in bulk. Fixed wholesale prices. Min. order RM1,000. Delivery across Peninsular Malaysia.',
  ogImage = '/images/og-default.jpg',
  heroMode = false,
} = Astro.props;

const WA_NUMBER = '60168916381';
const WA_LINK   = `https://wa.me/${WA_NUMBER}?text=Hi%20Quinocycle!%20I%20would%20like%20to%20enquire%20about%20your%20carton%20boxes.`;

const navLinks = [
  { href: '/',        label: 'Home'    },
  { href: '/shop',    label: 'Shop'    },
  { href: '/blog',    label: 'Blog'    },
  { href: '/about',   label: 'About'   },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#ffc600" />

  <!-- Open Graph -->
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={Astro.url.href} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content="Quinocycle" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- SEO -->
  <link rel="canonical" href={Astro.url.href} />

  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Inter font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Quinocycle",
    "description": "Wholesale carton box supplier in Malaysia. New and used boxes in bulk.",
    "url": "https://www.quinocycle.com.my",
    "telephone": "+60168916381",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "MY"
    },
    "areaServed": "Peninsular Malaysia",
    "priceRange": "RM$$"
  }
  </script>
</head>

<body class="bg-surface font-body text-on-surface selection:bg-primary-container selection:text-on-primary-container">

  <!-- NAV -->
  <nav class={`fixed top-0 w-full z-50 bg-[#fdf9f0]/80 backdrop-blur-xl border-b border-[#d3c5ab]/20 transition-all duration-300${heroMode ? ' nav-hidden' : ''}`} id="nav">
    <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-7xl mx-auto">

      <!-- Logo -->
      <a href="/" aria-label="Quinocycle Home" class="flex items-center gap-2">
        <img src="/logo.png" alt="Quinocycle" class="h-14 md:h-16 w-auto" id="navLogo" />
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => {
          const isActive = link.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class={`font-headline font-bold uppercase text-sm tracking-tight transition-colors duration-300 pb-1 ${
                isActive
                  ? 'text-primary border-b-2 border-primary'
                  : 'text-secondary hover:text-primary'
              }`}
            >
              {link.label}
            </a>
          );
        })}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:inline-flex items-center gap-2 bg-[#25D366] text-white px-5 py-2 rounded-full font-headline font-bold text-xs uppercase tracking-wide hover:bg-[#1ebd5a] transition-colors duration-200"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href="/shop"
          class="hidden md:inline-flex bg-primary-container text-on-primary-container px-6 py-2 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:opacity-90 transition-all duration-200"
        >
          Order Now
        </a>

        <!-- Mobile hamburger -->
        <button class="md:hidden flex flex-col gap-[5px] p-1" id="navBurger" aria-label="Open menu">
          <span class="block w-6 h-[1.5px] bg-on-surface-variant transition-all duration-200 origin-center" id="b1"></span>
          <span class="block w-6 h-[1.5px] bg-on-surface-variant transition-all duration-200" id="b2"></span>
          <span class="block w-6 h-[1.5px] bg-on-surface-variant transition-all duration-200 origin-center" id="b3"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Drawer -->
    <div class="hidden flex-col px-6 pb-6 pt-2 bg-[#fdf9f0] border-t border-[#d3c5ab]/20" id="navMobile" aria-hidden="true">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-headline font-bold text-2xl tracking-tight py-3 border-b border-[#d3c5ab]/30 text-on-surface-variant hover:text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="flex flex-col gap-3 mt-5">
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-[#25D366] text-white py-3 rounded-full font-headline font-bold text-sm uppercase tracking-wide"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
        <a
          href="/shop"
          class="flex items-center justify-center bg-primary-container text-on-primary-container py-3 rounded-full font-headline font-bold text-sm uppercase tracking-widest"
        >
          Order Now
        </a>
      </div>
    </div>
  </nav>

  <main class={heroMode ? '' : 'pt-[88px] md:pt-[96px]'}>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="w-full border-t border-[#d3c5ab]/20 bg-[#fdf9f0]">
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        <!-- Brand column -->
        <div>
          <img src="/logo.png" alt="Quinocycle" class="h-10 w-auto mb-4" id="footerLogo" />
          <p class="font-body text-sm text-secondary leading-relaxed max-w-xs">
            New &amp; used carton boxes in bulk.<br />
            Peninsular Malaysia delivery. Fixed wholesale pricing.
          </p>
          <a
            href={WA_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-6 bg-[#25D366] text-white px-6 py-2.5 rounded-full font-headline font-bold text-xs uppercase tracking-wide hover:bg-[#1ebd5a] transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Order
          </a>
        </div>

        <!-- Links columns -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-8">
          <div class="flex flex-col gap-3">
            <h5 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-1">Quick Links</h5>
            <a href="/shop"    class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">Shop</a>
            <a href="/blog"    class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">Blog</a>
            <a href="/about"   class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">About Us</a>
            <a href="/contact" class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">Contact</a>
          </div>
          <div class="flex flex-col gap-3">
            <h5 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-1">Products</h5>
            <a href="/shop?filter=new"   class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">New Boxes</a>
            <a href="/shop?filter=used"  class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">Used Boxes</a>
            <a href="/shop?filter=S"     class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">Small Boxes</a>
            <a href="/shop?filter=XL"    class="font-body text-sm text-secondary hover:text-primary hover:underline decoration-primary-container underline-offset-4 transition-colors">XL Boxes</a>
          </div>
          <div class="flex flex-col gap-3">
            <h5 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-1">Info</h5>
            <p class="font-body text-sm text-secondary">Free delivery across <strong class="text-on-surface font-semibold">KL &amp; Selangor</strong> (For order above RM300)</p>
            <p class="font-body text-sm text-secondary">Coverage: <strong class="text-on-surface font-semibold">Peninsular MY</strong></p>
            <p class="font-body text-sm text-secondary">Fixed wholesale pricing</p>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-12 pt-6 border-t border-[#d3c5ab]/20 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="font-body text-xs text-secondary opacity-70">
          &copy; {new Date().getFullYear()} Quinocycle. All rights reserved.
        </p>
        <div class="flex gap-6">
          <a href="/privacy" class="font-body text-xs text-secondary hover:text-primary transition-colors">Privacy Policy</a>
          <a href="/terms"   class="font-body text-xs text-secondary hover:text-primary transition-colors">Terms of Use</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- WhatsApp Float -->
  <a
    href={WA_LINK}
    target="_blank"
    rel="noopener noreferrer"
    class="wa-ping fixed bottom-7 right-7 z-50 w-14 h-14 rounded-full bg-[#25D366] text-white flex items-center justify-center hover:scale-110 hover:bg-[#1ebd5a] transition-all duration-200"
    aria-label="Chat on WhatsApp"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script>
    // Sticky nav on scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        nav?.classList.add('border-[#d3c5ab]/30', 'shadow-sm');
      } else {
        nav?.classList.remove('border-[#d3c5ab]/30', 'shadow-sm');
      }
    });

    // Mobile menu toggle
    const burger = document.getElementById('navBurger');
    const mobile = document.getElementById('navMobile');
    const b1 = document.getElementById('b1');
    const b2 = document.getElementById('b2');
    const b3 = document.getElementById('b3');

    burger?.addEventListener('click', () => {
      const isOpen = mobile?.classList.toggle('hidden') === false;
      const nowOpen = !mobile?.classList.contains('hidden');
      mobile?.classList.toggle('flex', nowOpen);
      mobile?.setAttribute('aria-hidden', String(!nowOpen));
      // Animate hamburger
      if (nowOpen) {
        b1?.classList.add('rotate-45', 'translate-y-[7px]');
        b2?.classList.add('opacity-0');
        b3?.classList.add('-rotate-45', '-translate-y-[7px]');
      } else {
        b1?.classList.remove('rotate-45', 'translate-y-[7px]');
        b2?.classList.remove('opacity-0');
        b3?.classList.remove('-rotate-45', '-translate-y-[7px]');
      }
    });

    // Close on link click
    mobile?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobile.classList.add('hidden');
        mobile.classList.remove('flex');
        mobile.setAttribute('aria-hidden', 'true');
        b1?.classList.remove('rotate-45', 'translate-y-[7px]');
        b2?.classList.remove('opacity-0');
        b3?.classList.remove('-rotate-45', '-translate-y-[7px]');
      });
    });
  </script>
</body>
</html>

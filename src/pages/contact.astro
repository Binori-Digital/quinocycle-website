---
import Layout from '../layouts/Layout.astro';
const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20have%20an%20enquiry.';
---

<Layout
  title="Contact Quinocycle — Wholesale Carton Box Enquiries"
  description="Get in touch with Quinocycle for carton box wholesale enquiries. WhatsApp us for the fastest response. Serving Peninsular Malaysia."
>
  <!-- Hero -->
  <section class="pt-16 pb-16 px-6 md:px-8 max-w-7xl mx-auto">
    <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">Contact</span>
    <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface leading-[0.9] mb-6">
      Let's talk<br /><span class="text-primary italic">boxes.</span>
    </h1>
    <p class="font-body text-xl text-secondary max-w-lg leading-relaxed">
      WhatsApp is the fastest way to reach us. For detailed enquiries, use the form below.
    </p>
  </section>

  <!-- Body -->
  <section class="pb-24 px-6 md:px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Left: Info -->
      <div class="flex flex-col gap-6">
        <!-- WhatsApp card -->
        <div class="bg-[#25D366] rounded-3xl p-8 flex gap-6 items-start editorial-shadow">
          <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <h3 class="font-headline font-bold text-xl text-white mb-2">WhatsApp (Fastest)</h3>
            <p class="font-body text-white/80 text-sm leading-relaxed mb-5">Reach us directly. We typically respond within a few hours during business hours.</p>
            <a
              href={WA_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white text-[#25D366] px-7 py-3 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:bg-white/90 transition-colors"
            >
              Chat on WhatsApp
            </a>
          </div>
        </div>

        <!-- Business details -->
        <div class="bg-surface-container-low rounded-3xl p-8 flex flex-col gap-7">
          <div>
            <h4 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-2">Company</h4>
            <p class="font-body text-on-surface font-semibold">Quinocycle Sdn. Bhd.</p>
            <p class="font-body text-sm text-secondary mt-0.5">SSM Reg No: 202001029919</p>
          </div>

          <div>
            <h4 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-2">Office &amp; Warehouse</h4>
            <p class="font-body text-on-surface-variant leading-relaxed">
              No.13, Jalan Taming P/1, Taming Jaya,<br />
              43300 Balakong, Selangor, Malaysia.
            </p>
            <a
              href="https://maps.google.com/?q=No.13+Jalan+Taming+P/1+Taming+Jaya+43300+Balakong+Selangor"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 mt-3 text-primary font-headline font-bold text-sm hover:underline"
            >
              <span class="material-symbols-outlined" style="font-size:16px;">location_on</span>
              View on Google Maps
            </a>
          </div>

          <div>
            <h4 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-3">Operating Hours</h4>
            <div class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm font-body">
              <span class="text-secondary">Monday – Friday</span>
              <span class="font-semibold text-on-surface">9:00 AM – 6:00 PM</span>
              <span class="text-secondary">Saturday</span>
              <span class="font-semibold text-on-surface">9:00 AM – 1:00 PM</span>
              <span class="text-secondary">Sunday / Public Holiday</span>
              <span class="font-semibold text-on-surface">Closed</span>
            </div>
          </div>

          <div>
            <h4 class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-2">Order Info</h4>
            <ul class="space-y-2 font-body text-sm text-on-surface-variant">
              <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" style="font-size:16px;">check_circle</span> Free delivery across KL &amp; Selangor (order above RM300)</li>
              <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" style="font-size:16px;">check_circle</span> Fixed wholesale pricing</li>
              <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" style="font-size:16px;">check_circle</span> Peninsular Malaysia delivery</li>
              <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary" style="font-size:16px;">check_circle</span> B2B invoice available</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-surface-container-low rounded-3xl p-8 md:p-10">
        <h2 class="font-headline text-2xl font-bold text-on-surface mb-2">Send an Enquiry</h2>
        <p class="font-body text-sm text-secondary mb-8 leading-relaxed">Fill in the form and we'll get back to you on WhatsApp or email within 1 business day.</p>

        <form class="flex flex-col gap-5" id="contactForm">
          <div>
            <label class="font-label text-xs font-bold uppercase tracking-[0.15em] text-secondary block mb-2" for="name">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Ahmad bin Ali"
              required
              class="w-full bg-surface border border-outline-variant/40 rounded-xl px-4 py-3 text-sm font-body text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all"
            />
          </div>

          <div>
            <label class="font-label text-xs font-bold uppercase tracking-[0.15em] text-secondary block mb-2" for="company">Company (Optional)</label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Your Company Sdn. Bhd."
              class="w-full bg-surface border border-outline-variant/40 rounded-xl px-4 py-3 text-sm font-body text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all"
            />
          </div>

          <div>
            <label class="font-label text-xs font-bold uppercase tracking-[0.15em] text-secondary block mb-2" for="phone">WhatsApp / Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="+60 12-345 6789"
              required
              class="w-full bg-surface border border-outline-variant/40 rounded-xl px-4 py-3 text-sm font-body text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all"
            />
          </div>

          <div>
            <label class="font-label text-xs font-bold uppercase tracking-[0.15em] text-secondary block mb-2" for="product">Product Interest</label>
            <select
              id="product"
              name="product"
              class="w-full bg-surface border border-outline-variant/40 rounded-xl px-4 py-3 text-sm font-body text-on-surface focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all"
            >
              <option value="">Select a product category</option>
              <option value="new-boxes">New Carton Boxes</option>
              <option value="used-boxes">Used Carton Boxes</option>
              <option value="mixed">Both New & Used</option>
              <option value="other">Other / Not Sure</option>
            </select>
          </div>

          <div>
            <label class="font-label text-xs font-bold uppercase tracking-[0.15em] text-secondary block mb-2" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Tell us about your order — box sizes, estimated quantity, delivery location..."
              required
              class="w-full bg-surface border border-outline-variant/40 rounded-xl px-4 py-3 text-sm font-body text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-on-surface text-surface py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-primary transition-colors duration-200"
          >
            Send Enquiry via WhatsApp
          </button>

          <p class="text-center font-body text-xs text-secondary">By submitting, you'll be redirected to WhatsApp with your message pre-filled.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contactForm');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form as HTMLFormElement);
    const name    = data.get('name');
    const company = data.get('company');
    const phone   = data.get('phone');
    const product = data.get('product');
    const message = data.get('message');

    let msg = `Hi Quinocycle! I have an enquiry:\n\n`;
    msg += `Name: ${name}\n`;
    if (company) msg += `Company: ${company}\n`;
    msg += `Phone: ${phone}\n`;
    if (product) msg += `Interested in: ${product}\n`;
    msg += `\nMessage:\n${message}`;

    window.open(`https://wa.me/60168916381?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>

---
import Layout from '../layouts/Layout.astro';
const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20have%20an%20enquiry.';
---

<Layout
  title="Contact Quinocycle — Wholesale Carton Box Enquiries"
  description="Get in touch with Quinocycle for carton box wholesale enquiries. WhatsApp us for the fastest response. Serving Peninsular Malaysia."
>
  <section class="contact-hero">
    <div class="container">
      <div class="section-eyebrow" style="color:rgba(255,255,255,0.5)">Contact</div>
      <h1 class="contact-hero__title">Let's talk<br /><span>boxes.</span></h1>
      <p class="contact-hero__sub">WhatsApp is the fastest way to reach us. For detailed enquiries, use the form below.</p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-body__inner">

      <!-- Left: Info -->
      <div class="contact-info">
        <div class="contact-card contact-card--wa">
          <div class="contact-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <h3 class="contact-card__title">WhatsApp (Fastest)</h3>
            <p class="contact-card__body">Reach us directly on WhatsApp. We typically respond within a few hours during business hours.</p>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa" style="margin-top:1rem">
              Chat on WhatsApp
            </a>
          </div>
        </div>

        <div class="contact-details">
          <div class="contact-detail">
            <div class="contact-detail__label">Company</div>
            <div class="contact-detail__val"><strong>Quinocycle Sdn. Bhd.</strong></div>
            <div class="contact-detail__val contact-detail__ssm">SSM Reg No: 202001029919</div>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Office &amp; Retail Warehouse</div>
            <div class="contact-detail__val">
              No.13, Jalan Taming P/1, Taming Jaya,<br />
              43300 Balakong, Selangor, Malaysia.
            </div>
            <a
              href="https://maps.google.com/?q=No.13+Jalan+Taming+P/1+Taming+Jaya+43300+Balakong+Selangor"
              target="_blank"
              rel="noopener noreferrer"
              class="contact-detail__map"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              View on Google Maps
            </a>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Operating Hours</div>
            <div class="contact-detail__hours-grid">
              <span>Mon – Fri</span><span>8.30am – 5.00pm</span>
              <span>Saturday</span><span>8.30am – 1.00pm</span>
              <span>Sun &amp; Public Holidays</span><span class="contact-detail__closed">CLOSED</span>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Phone</div>
            <div class="contact-detail__val"><a href="tel:+60389626381">03-8962 6381</a></div>
            <div class="contact-detail__val"><a href="tel:+60389616381">03-8961 6381</a></div>
            <div class="contact-detail__val"><a href="tel:+60168916381">016-891 6381</a> <span class="contact-detail__tag">Mobile / WhatsApp</span></div>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Email</div>
            <div class="contact-detail__val"><a href="mailto:sales@quinocycle.com">sales@quinocycle.com</a></div>
          </div>
          <div class="contact-detail">
            <div class="contact-detail__label">Min. Order</div>
            <div class="contact-detail__val">RM 1,000 · Fixed wholesale pricing</div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-form-wrap">
        <h2 class="contact-form-title">Send us a message</h2>
        <p class="contact-form-sub">We'll get back to you within 1 business day.</p>

        <form class="contact-form" id="contactForm" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label for="name">Your Name <span aria-hidden="true">*</span></label>
              <input type="text" id="name" name="name" placeholder="Ahmad Razif" required autocomplete="name" />
            </div>
            <div class="form-field">
              <label for="company">Company / Business</label>
              <input type="text" id="company" name="company" placeholder="My Sdn Bhd (optional)" autocomplete="organization" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="phone">Phone / WhatsApp <span aria-hidden="true">*</span></label>
              <input type="tel" id="phone" name="phone" placeholder="012-345 6789" required autocomplete="tel" />
            </div>
            <div class="form-field">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" autocomplete="email" />
            </div>
          </div>
          <div class="form-field">
            <label for="interest">I am interested in</label>
            <select id="interest" name="interest">
              <option value="">Select a product type...</option>
              <option>New carton boxes</option>
              <option>Used / recycled carton boxes</option>
              <option>Both new and used boxes</option>
              <option>General enquiry</option>
            </select>
          </div>
          <div class="form-field">
            <label for="message">Message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your requirements — box sizes, estimated quantity per month, delivery location, etc." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg form-submit">
            Send Message
          </button>
          <p class="form-note">* Required fields. We respect your privacy and won't share your information.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = form?.querySelector('.form-submit') as HTMLButtonElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name    = data.get('name') as string;
    const company = data.get('company') as string;
    const phone   = data.get('phone') as string;
    const email   = data.get('email') as string;
    const interest = data.get('interest') as string;
    const message = data.get('message') as string;

    // Build WhatsApp message
    let msg = `Hi Quinocycle! Here is my enquiry:\n\n`;
    msg += `Name: ${name}\n`;
    if (company) msg += `Company: ${company}\n`;
    msg += `Phone: ${phone}\n`;
    if (email) msg += `Email: ${email}\n`;
    if (interest) msg += `Interested in: ${interest}\n`;
    msg += `\nMessage:\n${message}`;

    const waUrl = `https://wa.me/60168916381?text=${encodeURIComponent(msg)}`;
    window.open(waUrl, '_blank', 'noopener,noreferrer');

    submitBtn.textContent = 'Message Sent ✓';
    submitBtn.style.background = '#25D366';
    setTimeout(() => {
      submitBtn.textContent = 'Send Message';
      submitBtn.style.background = '';
      form.reset();
    }, 3000);
  });
</script>

<style>
.contact-hero {
  background: var(--bg-base);
  padding-block: clamp(3rem, 6vw, 5rem);
  position: relative;
  overflow: hidden;
}
.contact-hero::before {
  content: '';
  position: absolute;
  top: -30%; right: -5%;
  width: 600px; height: 500px;
  background: radial-gradient(circle, rgba(245,196,0,0.07) 0%, transparent 70%);
  pointer-events: none;
  filter: blur(60px);
}
.contact-hero__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--text-1);
  margin-block: 1rem;
  position: relative;
  z-index: 1;
}
.contact-hero__title span { color: var(--yellow); text-shadow: var(--glow-text); }
.contact-hero__sub {
  font-size: 1rem;
  line-height: 1.6;
  color: var(--text-2);
  max-width: 480px;
  position: relative;
  z-index: 1;
}

.contact-body { padding-block: var(--section-py); background: var(--bg-base); }
.contact-body__inner {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 4rem;
  align-items: start;
}
@media (max-width: 900px) {
  .contact-body__inner { grid-template-columns: 1fr; gap: 2.5rem; }
}

.contact-info { display: flex; flex-direction: column; gap: 1.5rem; }

.contact-card {
  display: flex;
  gap: 1.25rem;
  padding: 1.75rem;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  transition: border-color 0.2s, box-shadow 0.2s;
}
.contact-card--wa {
  border-color: rgba(37,211,102,0.3);
  background: rgba(37,211,102,0.04);
}
.contact-card--wa:hover { box-shadow: 0 0 20px rgba(37,211,102,0.15); }
.contact-card:not(.contact-card--wa):hover {
  border-color: var(--border-yellow);
  box-shadow: var(--glow-sm);
}
.contact-card__icon {
  width: 48px; height: 48px;
  background: #25D366;
  color: var(--white);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.contact-card__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--text-1);
  margin-bottom: 0.5rem;
}
.contact-card__body {
  font-size: 0.875rem;
  line-height: 1.65;
  color: var(--text-2);
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.5rem;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  backdrop-filter: blur(12px);
}
.contact-detail { display: flex; flex-direction: column; gap: 2px; }
.contact-detail__label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-3);
}
.contact-detail__val {
  font-size: 0.9rem;
  color: var(--text-1);
  font-weight: 500;
}
.contact-detail + .contact-detail { border-top: 1px solid var(--border); padding-top: 1rem; }
.contact-detail__ssm {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-3);
  margin-top: 2px;
}
.contact-detail__map {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-top: 6px;
  transition: text-shadow 0.15s;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.contact-detail__map:hover { text-shadow: var(--glow-text); }
.contact-detail__hours-grid {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4px 16px;
  font-size: 0.875rem;
  color: var(--text-1);
  margin-top: 4px;
}
.contact-detail__hours-grid span:nth-child(odd) { color: var(--text-3); }
.contact-detail__closed {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: #fc8181;
}
.contact-detail__val a {
  color: var(--text-1);
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.15s;
}
.contact-detail__val a:hover { color: var(--yellow); }
.contact-detail__tag {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: rgba(245,196,0,0.15);
  color: var(--yellow);
  border: 1px solid var(--border-yellow);
  padding: 2px 6px;
  border-radius: 2px;
  margin-left: 6px;
  vertical-align: middle;
}

/* Form */
.contact-form-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
.contact-form-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  color: var(--text-1);
}
.contact-form-sub {
  font-size: 0.875rem;
  color: var(--text-2);
  margin-bottom: 1rem;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
.form-field {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.form-field label span { color: var(--yellow); }
.form-field textarea { resize: vertical; min-height: 120px; }
.form-field select { cursor: pointer; }

.form-submit { align-self: flex-start; transition: background 0.3s, transform 0.15s; }
.form-note {
  font-size: 0.75rem;
  color: var(--text-3);
  line-height: 1.5;
}
</style>

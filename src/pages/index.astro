---
import Layout from '../layouts/Layout.astro';

const WA_NUMBER = '60168916381'; // TODO: Replace with your WhatsApp number
const WA_LINK   = `https://wa.me/${WA_NUMBER}?text=Hi%20Quinocycle!%20I%20would%20like%20to%20enquire%20about%20your%20carton%20boxes.`;

const audiences = [
  {
    img: '/images/audience-retail.jpg',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    label: 'Retail & SME',
    headline: 'Never run out of packaging.',
    body: 'Stock up once, save more per box. Consistent supply for your daily operations — no more last-minute runs.',
    cta: 'Shop Now',
    href: '/shop?segment=retail',
  },
  {
    img: '/images/audience-online.jpg',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
    label: 'Online Sellers',
    headline: 'Right box for every order.',
    body: 'From Shopee to TikTok Shop — get bulk boxes in sizes that protect your products and impress your buyers.',
    cta: 'See Sizes',
    href: '/shop?segment=online',
  },
  {
    img: '/images/audience-mover.jpg',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    label: 'Mover Companies',
    headline: 'High volume. Fast turnaround.',
    body: 'Moving more clients every month? We handle your bulk orders reliably so you can keep every move on schedule.',
    cta: 'Get a Quote',
    href: `${WA_LINK}&text=Hi%20Quinocycle!%20I%20am%20a%20mover%20company%20looking%20for%20bulk%20box%20supply.`,
  },
  {
    img: '/images/audience-logistics.jpg',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
    label: 'Logistics & Warehousing',
    headline: 'Reliable supply. B2B-ready.',
    body: 'Consistent quality, volume pricing, and proper invoicing. We understand logistics — so your supply never stops.',
    cta: 'Talk to Us',
    href: WA_LINK,
  },
];

const steps = [
  { num: '01', title: 'Browse & Pick', body: 'Choose your box type (new or used) and the sizes you need from our fixed price catalogue.' },
  { num: '02', title: 'Order or WhatsApp', body: 'Place your order online or send us a WhatsApp. Min. order is RM 1,000. We confirm within 1 business day.' },
  { num: '03', title: 'We Deliver', body: 'Fast delivery across Peninsular Malaysia. Track your shipment and unbox your savings.' },
];

const features = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, title: 'Fixed Wholesale Prices', body: 'No hidden fees. No negotiation fatigue. Transparent pricing you can budget around.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>`, title: 'New & Used Options', body: 'Budget-conscious? Used boxes save up to 50%. Eco-conscious? Recycling reduces your carbon footprint.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, title: 'Fast Delivery', body: 'Covering all of Peninsular Malaysia. Efficient logistics so you get your boxes when you need them.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>`, title: 'WhatsApp Support', body: 'Talk to a real person fast. We respond on WhatsApp within business hours — no robots, no waiting.' },
];

const testimonials = [
  { quote: 'We order 500+ boxes a month for our Shopee store. Quinocycle is the most reliable supplier we\'ve worked with. Pricing is clear, no surprises.', name: 'Ahmad Razif', role: 'Shopee Seller, Selangor' },
  { quote: 'As a mover company, box supply is critical. Quinocycle delivers on time every time. The used boxes are strong and our customers love that we\'re being eco-friendly.', name: 'Lim Wei Hong', role: 'Operations Manager, KL Movers' },
  { quote: 'Setup costs were high when we started our warehouse. Quinocycle\'s wholesale pricing helped us cut packaging cost by 40%. B2B invoice is a bonus.', name: 'Siti Norzalina', role: 'Logistics Manager, Penang' },
];

const blogPosts = [
  {
    slug: 'kedai-kotak-pindah-malaysia',
    category: 'Panduan Pindah Rumah',
    img: '/images/blog-movers-guide.jpg',
    title: 'Kedai Kotak Pindah Malaysia — Quinocycle, Balakong Selangor',
    excerpt: 'Cari kotak pindah rumah murah? Kami jual kotak kardus baru & terpakai dari RM 0.90/kotak. Senarai lengkap barang penting untuk pindah rumah.',
    date: '2026-04-08',
    readTime: '7 min',
  },
  {
    slug: 'choose-right-carton-box-size',
    category: 'Packaging Tips',
    img: '/images/blog-choose-box-size.jpg',
    title: 'How to Choose the Right Carton Box Size for Your Business',
    excerpt: 'Choosing the wrong size wastes money and damages goods. Here\'s the simple guide to sizing your boxes perfectly.',
    date: '2026-03-15',
    readTime: '5 min',
  },
  {
    slug: 'new-vs-used-carton-boxes',
    category: 'Buyer Guide',
    img: '/images/blog-new-vs-used.jpg',
    title: 'New vs Used Carton Boxes — Which is Right for You?',
    excerpt: 'Used boxes can cut your packaging cost by up to 50%. But are they right for your products? We break it down.',
    date: '2026-03-08',
    readTime: '4 min',
  },
  {
    slug: 'cut-packaging-costs-online-seller',
    category: 'Business Tips',
    img: '/images/blog-cut-packaging-costs.jpg',
    title: 'How Online Sellers Can Cut Packaging Costs by 40%',
    excerpt: 'Small margins matter for e-commerce. These practical steps will save you thousands in packaging every year.',
    date: '2026-02-28',
    readTime: '6 min',
  },
];
---

<Layout>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <div class="tag tag--dark fade-up">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="5"/></svg>
          Wholesale Carton Box Supplier · Malaysia
        </div>

        <h1 class="hero__heading fade-up fade-up-1">
          Box More.<br />
          <span class="hero__heading-accent">Spend Less.</span>
        </h1>

        <p class="hero__sub fade-up fade-up-2">
          New &amp; used carton boxes in bulk — fixed wholesale prices, Peninsular Malaysia delivery.
          Trusted by retailers, online sellers, movers and logistics companies.
        </p>

        <div class="hero__meta fade-up fade-up-3">
          <span class="meta-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Min. Order RM 1,000
          </span>
          <span class="meta-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Fixed Wholesale Pricing
          </span>
          <span class="meta-chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Peninsular Malaysia Delivery
          </span>
        </div>

        <div class="hero__ctas fade-up fade-up-4">
          <a href="/shop" class="btn btn-primary btn-lg">Browse the Shop</a>
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>

      <!-- Hero visual -->
      <div class="hero__visual fade-up fade-up-2">
        <img
          src="/images/hero-boxes.jpg"
          alt="Stacked carton boxes in warehouse"
          class="hero__img"
          loading="eager"
          width="640"
          height="360"
        />
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="hero__scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ===================== TRUST BAR ===================== -->
  <section class="trust-bar" aria-label="Trust indicators">
    <div class="trust-bar__inner">
      <div class="marquee-track">
        {[...Array(2)].map(() => (
          <>
            <span class="trust-item">500+ Businesses Served</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">Fixed Wholesale Pricing</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">New &amp; Used Boxes Available</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">Peninsular Malaysia Delivery</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">Min. Order RM 1,000</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">WhatsApp Support</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
            <span class="trust-item">Eco-Friendly Used Boxes</span>
            <span class="trust-dot" aria-hidden="true">◆</span>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== WHO WE SERVE ===================== -->
  <section class="audiences" id="who-we-serve">
    <div class="container">
      <div class="section-eyebrow">Who We Serve</div>
      <h2 class="section-title audiences__heading">
        Built for Malaysian<br />businesses that move.
      </h2>

      <div class="audiences__grid">
        {audiences.map((a, i) => (
          <div class="aud-card" style={`--delay: ${i * 0.1}s`}>
            <div class="aud-card__img-wrap">
              <img src={a.img} alt={a.label} class="aud-card__img" loading="lazy" width="400" height="300" />
            </div>
            <div class="aud-card__icon" set:html={a.icon} />
            <div class="aud-card__tag">{a.label}</div>
            <h3 class="aud-card__title">{a.headline}</h3>
            <p class="aud-card__body">{a.body}</p>
            <a href={a.href} class="aud-card__link">
              {a.cta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PRODUCTS ===================== -->
  <section class="products" id="products">
    <div class="container">
      <div class="section-eyebrow">What We Sell</div>
      <h2 class="section-title products__heading">Two great options.<br />One trusted supplier.</h2>
    </div>

    <div class="products__split">
      <!-- NEW BOXES -->
      <div class="prod-panel prod-panel--new">
        <div class="prod-panel__content">
          <div class="tag tag--dark">New Boxes</div>
          <h3 class="prod-panel__title">Brand New<br />Carton Boxes</h3>
          <ul class="prod-panel__list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Consistent quality &amp; dimensions
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Single and double wall options
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Professional finish for e-commerce
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Available in S / M / L / XL sizes
            </li>
          </ul>
          <div class="prod-panel__price">From <strong>RM 1.90</strong> / box</div>
          <a href="/shop?filter=new" class="btn btn-dark">Shop New Boxes</a>
        </div>
        <div class="prod-panel__visual prod-panel__visual--new">
          <img
            src="/images/product-new.jpg"
            alt="Brand new corrugated carton boxes"
            class="prod-panel__img"
            loading="lazy"
            width="480"
            height="640"
          />
          <div class="prod-badge prod-badge--new">NEW</div>
        </div>
      </div>

      <!-- USED BOXES -->
      <div class="prod-panel prod-panel--used">
        <div class="prod-panel__visual prod-panel__visual--used">
          <img
            src="/images/product-used.jpg"
            alt="Recycled used carton boxes — eco-friendly"
            class="prod-panel__img"
            loading="lazy"
            width="480"
            height="640"
          />
          <div class="prod-badge prod-badge--used">USED</div>
        </div>
        <div class="prod-panel__content">
          <div class="tag tag--yellow">Used Boxes</div>
          <h3 class="prod-panel__title prod-panel__title--light">Used &amp; Recycled<br />Carton Boxes</h3>
          <ul class="prod-panel__list prod-panel__list--light">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Save up to 50% vs new boxes
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Still sturdy — quality checked
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Eco-friendly packaging choice
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Ideal for movers &amp; storage
            </li>
          </ul>
          <div class="prod-panel__price prod-panel__price--light">From <strong>RM 0.90</strong> / box</div>
          <a href="/shop?filter=used" class="btn btn-primary">Shop Used Boxes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-eyebrow">How It Works</div>
      <h2 class="section-title hiw__heading">Order in 3 simple steps.</h2>
      <div class="hiw__steps">
        {steps.map((s, i) => (
          <div class="hiw-step" style={`--delay: ${i * 0.12}s`}>
            <div class="hiw-step__num">{s.num}</div>
            <div class="hiw-step__content">
              <h3 class="hiw-step__title">{s.title}</h3>
              <p class="hiw-step__body">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="hiw__cta">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Start Your Order
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== WHY CHOOSE ===================== -->
  <section class="why">
    <div class="container">
      <div class="section-eyebrow">Why Quinocycle</div>
      <h2 class="section-title why__heading">We make bulk buying<br />straightforward.</h2>
      <div class="why__grid">
        {features.map((f, i) => (
          <div class="why-card" style={`--delay: ${i * 0.08}s`}>
            <div class="why-card__icon" set:html={f.icon} />
            <h3 class="why-card__title">{f.title}</h3>
            <p class="why-card__body">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="testimonials">
    <div class="container">
      <div class="section-eyebrow">What Customers Say</div>
      <h2 class="section-title testi__heading">Trusted by<br />businesses across Malaysia.</h2>
      <div class="testi__grid">
        {testimonials.map((t, i) => (
          <div class="testi-card" style={`--delay: ${i * 0.1}s`}>
            <div class="testi-card__quote-mark">"</div>
            <p class="testi-card__quote">{t.quote}</p>
            <div class="testi-card__author">
              <div class="testi-card__avatar" aria-hidden="true">{t.name[0]}</div>
              <div>
                <div class="testi-card__name">{t.name}</div>
                <div class="testi-card__role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== BLOG PREVIEW ===================== -->
  <section class="blog-preview">
    <div class="container">
      <div class="blog-preview__header">
        <div>
          <div class="section-eyebrow">From the Blog</div>
          <h2 class="section-title blog-preview__heading">Packaging tips &amp;<br />business insights.</h2>
        </div>
        <a href="/blog" class="btn btn-outline hide-mobile">View All Articles</a>
      </div>

      <div class="blog-preview__grid">
        {blogPosts.map((p, i) => (
          <a href={`/blog/${p.slug}`} class="blog-card" style={`--delay: ${i * 0.1}s`}>
            <div class="blog-card__img-wrap">
              <img src={p.img} alt={p.title} class="blog-card__img" loading="lazy" width="640" height="360" />
            </div>
            <div class="blog-card__body">
              <div class="tag tag--yellow" style="font-size:0.62rem">{p.category}</div>
              <h3 class="blog-card__title">{p.title}</h3>
              <p class="blog-card__excerpt">{p.excerpt}</p>
              <div class="blog-card__meta">
                <time datetime={p.date}>{new Date(p.date).toLocaleDateString('en-MY', { day:'numeric', month:'short', year:'numeric' })}</time>
                <span>{p.readTime} read</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="blog-preview__mobile-cta hide-desktop">
        <a href="/blog" class="btn btn-outline">View All Articles</a>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="final-cta">
    <div class="container final-cta__inner">
      <div class="final-cta__content">
        <div class="tag tag--yellow">Ready to Order?</div>
        <h2 class="final-cta__heading">
          Great prices.<br />Simple ordering.<br />
          <span class="final-cta__heading-accent">Let's talk boxes.</span>
        </h2>
        <p class="final-cta__sub">
          Minimum order RM 1,000 · Fixed pricing · Delivery across Peninsular Malaysia
        </p>
      </div>

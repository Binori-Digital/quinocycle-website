---
import Layout from '../layouts/Layout.astro';

const WA_NUMBER = '60168916381';
const WA_LINK   = `https://wa.me/${WA_NUMBER}?text=Hi%20Quinocycle!%20I%20would%20like%20to%20enquire%20about%20your%20carton%20boxes.`;

const audiences = [
  {
    img: '/images/audience-online.jpg',
    label: 'Online Sellers',
    headline: 'Right box for every order.',
    body: 'From Shopee to TikTok Shop — bulk boxes in sizes that protect your products and impress your buyers.',
    cta: 'See Sizes',
    href: '/shop?segment=online',
    span: 'md:col-span-8',
  },
  {
    img: '/images/audience-retail.jpg',
    label: 'Retail & SME',
    headline: 'Never run out of packaging.',
    body: 'Stock up once, save more per box. Consistent supply for your daily operations.',
    cta: 'Shop Now',
    href: '/shop?segment=retail',
    span: 'md:col-span-4',
  },
  {
    img: '/images/audience-mover.jpg',
    label: 'Mover Companies',
    headline: 'High volume. Fast turnaround.',
    body: 'We handle bulk orders reliably so you can keep every move on schedule.',
    cta: 'Get a Quote',
    href: WA_LINK,
    span: 'md:col-span-4',
  },
  {
    img: '/images/audience-logistics.jpg',
    label: 'Logistics & Warehousing',
    headline: 'Reliable supply. B2B-ready.',
    body: 'Consistent quality, volume pricing, and proper invoicing.',
    cta: 'Talk to Us',
    href: WA_LINK,
    span: 'md:col-span-8',
  },
];

const features = [
  { icon: 'paid',           title: 'Fixed Wholesale Prices',  body: 'No hidden fees. No negotiation fatigue. Transparent pricing you can budget around.' },
  { icon: 'inventory_2',    title: 'New & Used Options',       body: 'Used boxes save up to 50%. Eco-conscious buying that reduces your carbon footprint.' },
  { icon: 'local_shipping', title: 'Fast Delivery',            body: 'Covering all of Peninsular Malaysia. Efficient logistics so boxes arrive when needed.' },
  { icon: 'chat',           title: 'WhatsApp Support',         body: 'Talk to a real person fast. We respond on WhatsApp within business hours.' },
];

const steps = [
  { num: '01', title: 'Browse & Pick',       body: 'Choose your box type (new or used) and sizes from our fixed-price catalogue.' },
  { num: '02', title: 'Order or WhatsApp',   body: 'Place online or send a WhatsApp. Min. order RM 1,000. We confirm within 1 business day.' },
  { num: '03', title: 'We Deliver',          body: 'Fast delivery across Peninsular Malaysia. Track your shipment and unbox your savings.' },
];

const testimonials = [
  { quote: 'We order 500+ boxes a month for our Shopee store. Quinocycle is the most reliable supplier we\'ve worked with. Pricing is clear, no surprises.', name: 'Ahmad Razif', role: 'Shopee Seller, Selangor' },
  { quote: 'As a mover company, box supply is critical. Quinocycle delivers on time every time. The used boxes are strong and our customers love the eco angle.', name: 'Lim Wei Hong', role: 'Operations Manager, KL Movers' },
  { quote: 'Quinocycle\'s wholesale pricing helped us cut packaging cost by 40%. B2B invoice is a great bonus for our accounting.', name: 'Siti Norzalina', role: 'Logistics Manager, Penang' },
];

const blogPosts = [
  {
    slug: 'kedai-kotak-pindah-malaysia',
    category: 'Panduan Pindah Rumah',
    img: '/images/blog-movers-guide.jpg',
    title: 'Kedai Kotak Pindah Malaysia — Quinocycle, Balakong Selangor',
    excerpt: 'Cari kotak pindah rumah murah? Kami jual kotak kardus baru & terpakai dari RM 0.90/kotak.',
    date: '2026-04-08',
    readTime: '7 min',
  },
  {
    slug: 'choose-right-carton-box-size',
    category: 'Packaging Tips',
    img: '/images/blog-choose-box-size.jpg',
    title: 'How to Choose the Right Carton Box Size',
    excerpt: 'Choosing the wrong size wastes money and damages goods. Here\'s the simple sizing guide.',
    date: '2026-03-15',
    readTime: '5 min',
  },
  {
    slug: 'new-vs-used-carton-boxes',
    category: 'Buyer Guide',
    img: '/images/blog-new-vs-used.jpg',
    title: 'New vs Used Carton Boxes — Which is Right for You?',
    excerpt: 'Used boxes can cut your packaging cost by up to 50%. But are they right for your products?',
    date: '2026-03-08',
    readTime: '4 min',
  },
  {
    slug: 'cut-packaging-costs-online-seller',
    category: 'Business Tips',
    img: '/images/blog-cut-packaging-costs.jpg',
    title: 'How Online Sellers Can Cut Packaging Costs by 40%',
    excerpt: 'Small margins matter for e-commerce. These practical steps will save you thousands yearly.',
    date: '2026-02-28',
    readTime: '6 min',
  },
];
---

<Layout>
  <!-- ===================== NEU HERO ===================== -->
  <section class="relative min-h-screen flex items-center overflow-hidden">

    <!-- Background image + overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/hero-boxes.jpg"
        alt="Quinocycle carton boxes warehouse"
        class="w-full h-full object-cover"
      />
      <!-- Dark overlay so card pops -->
      <div class="absolute inset-0 bg-[#1d1c16]/55"></div>
    </div>

    <!-- Content wrapper -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-8 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

        <!-- ── MAIN CARD ── -->
        <div class="lg:col-span-7 neu-card bg-surface border-2 border-[#1d1c16] p-8 md:p-12 fade-up">

          <!-- Eyebrow tag -->
          <div class="inline-flex items-center gap-2 bg-primary-container border-2 border-[#1d1c16] px-4 py-2 mb-8 neu-tag">
            <span class="w-2 h-2 rounded-full bg-[#1d1c16] flex-shrink-0"></span>
            <span class="font-label text-xs font-black uppercase tracking-[0.2em] text-on-surface">
              Wholesale Carton Boxes · Malaysia
            </span>
          </div>

          <!-- Headline -->
          <h1 class="font-headline font-black tracking-tighter leading-[0.88] text-on-surface mb-6 fade-up fade-up-1"
              style="font-size: clamp(3rem, 7vw, 6rem);">
            Box More.<br />
            <span class="relative inline-block">
              <span class="relative z-10">Spend Less.</span>
              <span class="absolute inset-x-0 bottom-1 h-[40%] bg-primary-container z-0" aria-hidden="true"></span>
            </span>
          </h1>

          <!-- Sub -->
          <p class="font-body text-on-surface-variant text-lg leading-relaxed mb-8 max-w-lg fade-up fade-up-2">
            New &amp; used carton boxes in bulk — fixed wholesale prices,
            Peninsular Malaysia delivery. Trusted by retailers, online sellers,
            movers and logistics companies.
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4 mb-10 fade-up fade-up-3">
            <a href="/shop"
               class="neu-btn-amber inline-flex items-center gap-2 bg-primary-container text-on-surface px-8 py-4 border-2 border-[#1d1c16] font-headline font-black text-sm uppercase tracking-widest">
              Browse the Shop
              <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
            </a>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
               class="neu-btn-wa inline-flex items-center gap-2 bg-[#25D366] text-white px-8 py-4 border-2 border-[#1d1c16] font-headline font-black text-sm uppercase tracking-widest">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Us
            </a>
          </div>

          <!-- Stats grid (neubrutalist bordered cells) -->
          <div class="grid grid-cols-3 border-2 border-[#1d1c16] fade-up fade-up-4">
            <div class="p-4 md:p-5 border-r-2 border-[#1d1c16]">
              <div class="font-headline font-black text-2xl md:text-3xl text-primary leading-none mb-1">500+</div>
              <div class="font-label text-[10px] uppercase tracking-widest text-secondary leading-snug">Businesses<br/>Served</div>
            </div>
            <div class="p-4 md:p-5 border-r-2 border-[#1d1c16]">
              <div class="font-headline font-black text-2xl md:text-3xl text-primary leading-none mb-1">RM1k</div>
              <div class="font-label text-[10px] uppercase tracking-widest text-secondary leading-snug">Min.<br/>Order</div>
            </div>
            <div class="p-4 md:p-5">
              <div class="font-headline font-black text-2xl md:text-3xl text-primary leading-none mb-1">100%</div>
              <div class="font-label text-[10px] uppercase tracking-widest text-secondary leading-snug">Peninsular<br/>Malaysia</div>
            </div>
          </div>
        </div>

        <!-- ── FLOATING SIDE CARDS (desktop only) ── -->
        <div class="hidden lg:flex lg:col-span-5 flex-col gap-5 fade-up fade-up-2">

          <!-- Product preview card 1 -->
          <div class="neu-card-sm bg-surface border-2 border-[#1d1c16] overflow-hidden flex">
            <div class="w-28 flex-shrink-0 bg-surface-container-low">
              <img src="/images/box-new-l.jpg" alt="New carton box" class="w-full h-full object-cover" />
            </div>
            <div class="p-5 flex flex-col justify-between">
              <div>
                <span class="inline-block bg-primary-container border border-[#1d1c16] text-[10px] font-black uppercase tracking-widest px-2 py-0.5 mb-2">New Box</span>
                <h3 class="font-headline font-black text-base text-on-surface leading-tight">Large New Carton Box</h3>
                <p class="font-body text-xs text-secondary mt-1">60 × 40 × 40 cm · Double Wall</p>
              </div>
              <div class="flex items-center justify-between mt-3">
                <span class="font-headline font-black text-lg text-on-surface">RM 4.50<span class="text-xs font-normal text-secondary"> /box</span></span>
                <a href="/shop" class="text-primary font-headline font-black text-xs uppercase tracking-wider hover:underline">Order →</a>
              </div>
            </div>
          </div>

          <!-- Product preview card 2 -->
          <div class="neu-card-sm bg-primary-container border-2 border-[#1d1c16] overflow-hidden flex">
            <div class="w-28 flex-shrink-0 bg-primary-fixed">
              <img src="/images/box-used-l.jpg" alt="Used carton box" class="w-full h-full object-cover" />
            </div>
            <div class="p-5 flex flex-col justify-between">
              <div>
                <span class="inline-block bg-surface border border-[#1d1c16] text-[10px] font-black uppercase tracking-widest px-2 py-0.5 mb-2">Used Box</span>
                <h3 class="font-headline font-black text-base text-on-surface leading-tight">Large Used Carton Box</h3>
                <p class="font-body text-xs text-on-primary-container/70 mt-1">~60 × 40 × 40 cm · Double Wall</p>
              </div>
              <div class="flex items-center justify-between mt-3">
                <span class="font-headline font-black text-lg text-on-surface">RM 2.50<span class="text-xs font-normal text-on-primary-container/70"> /box</span></span>
                <a href="/shop" class="text-on-surface font-headline font-black text-xs uppercase tracking-wider hover:underline">Order →</a>
              </div>
            </div>
          </div>

          <!-- Mini info tag -->
          <div class="flex items-center gap-3 bg-[#1d1c16] border-2 border-[#1d1c16] px-5 py-3 neu-tag-dark">
            <span class="material-symbols-outlined text-primary-container" style="font-size:20px;">local_shipping</span>
            <span class="font-label text-xs font-black uppercase tracking-widest text-white">Fast Delivery · Peninsular Malaysia</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2">
      <span class="font-label text-[10px] uppercase tracking-widest text-white/50">Scroll</span>
      <div class="w-px h-8 bg-white/30 neu-scroll-pulse"></div>
    </div>
  </section>

  <style>
    /* ── Neubrutalist shadow classes ── */
    .neu-card     { box-shadow: 8px 8px 0 #1d1c16; }
    .neu-card-sm  { box-shadow: 5px 5px 0 #1d1c16; }
    .neu-tag      { box-shadow: 3px 3px 0 #1d1c16; }
    .neu-tag-dark { box-shadow: 4px 4px 0 rgba(255,255,255,0.15); }

    /* ── Button press-in effect ── */
    .neu-btn-amber,
    .neu-btn-wa {
      box-shadow: 4px 4px 0 #1d1c16;
      transition: transform 0.08s ease, box-shadow 0.08s ease;
    }
    .neu-btn-amber:hover,
    .neu-btn-wa:hover {
      transform: translate(4px, 4px);
      box-shadow: 0px 0px 0 #1d1c16;
    }
    .neu-btn-amber:active,
    .neu-btn-wa:active {
      transform: translate(4px, 4px);
      box-shadow: 0px 0px 0 #1d1c16;
    }

    /* ── Scroll pulse ── */
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; transform: scaleY(1);   }
      50%       { opacity: 1;   transform: scaleY(0.5); }
    }
    .neu-scroll-pulse { animation: scrollPulse 1.8s ease-in-out infinite; }
  </style>

  <!-- ===================== MARQUEE STRIPE ===================== -->
  <div class="w-full border-y-2 border-[#1d1c16] bg-primary-container overflow-hidden py-4">
    <div class="marquee-track">
      {[
        { icon: 'inventory_2',    text: 'New Carton Boxes' },
        { icon: 'recycling',      text: 'Used Carton Boxes' },
        { icon: 'paid',           text: 'Fixed Wholesale Pricing' },
        { icon: 'local_shipping', text: 'Peninsular Malaysia Delivery' },
        { icon: 'storefront',     text: 'Retail & SME Supply' },
        { icon: 'shopping_bag',   text: 'Online Seller Packaging' },
        { icon: 'package_2',      text: 'Bulk Orders Welcome' },
        { icon: 'support_agent',  text: 'WhatsApp Support' },
        { icon: 'inventory_2',    text: 'New Carton Boxes' },
        { icon: 'recycling',      text: 'Used Carton Boxes' },
        { icon: 'paid',           text: 'Fixed Wholesale Pricing' },
        { icon: 'local_shipping', text: 'Peninsular Malaysia Delivery' },
        { icon: 'storefront',     text: 'Retail & SME Supply' },
        { icon: 'shopping_bag',   text: 'Online Seller Packaging' },
        { icon: 'package_2',      text: 'Bulk Orders Welcome' },
        { icon: 'support_agent',  text: 'WhatsApp Support' },
      ].map(item => (
        <span class="inline-flex items-center gap-3 px-6 whitespace-nowrap">
          <span class="material-symbols-outlined text-[#1d1c16]" style="font-size:18px;">{item.icon}</span>
          <span class="font-headline font-black text-sm uppercase tracking-widest text-[#1d1c16]">{item.text}</span>
          <span class="text-[#1d1c16]/40 font-black text-lg" aria-hidden="true">✦</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ===================== WHO WE SERVE — BENTO GRID ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div class="max-w-xl">
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Who We Serve</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">Packaging for every kind of business.</h2>
        </div>
        <a href="/shop" class="text-primary font-headline font-bold border-b-2 border-primary-container hover:border-primary transition-all pb-1 whitespace-nowrap">Full Catalogue →</a>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-5">
        {audiences.map((a, i) => (
          <div class={`${a.span} bg-surface rounded-3xl overflow-hidden group relative min-h-[340px]`}>
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/60 via-on-surface/20 to-transparent z-10"></div>
            <img
              src={a.img}
              alt={a.label}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 p-8 z-20">
              <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary-container mb-3 block">{a.label}</span>
              <h3 class="font-headline text-2xl md:text-3xl font-bold text-white mb-3 leading-tight">{a.headline}</h3>
              <p class="text-white/75 text-sm leading-relaxed mb-5 max-w-sm">{a.body}</p>
              <a
                href={a.href}
                target={a.href.startsWith('http') ? '_blank' : undefined}
                rel={a.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="inline-flex bg-primary-container text-on-primary-container px-6 py-2.5 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:opacity-90 transition-all"
              >
                {a.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Why Quinocycle</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">
          The foundation of <span class="text-primary italic">reliability.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {features.map((f, i) => (
          <div class={`rounded-3xl p-8 flex flex-col gap-4 ${
            i === 3 ? 'bg-inverse-surface text-white' :
            i === 1 ? 'bg-primary-container' :
            'bg-surface-container-low'
          }`}>
            <span class={`material-symbols-outlined text-4xl ${
              i === 3 ? 'text-primary-container' :
              'text-primary'
            }`}>{f.icon}</span>
            <h4 class={`font-headline font-bold text-xl ${i === 3 ? 'text-white' : 'text-on-surface'}`}>{f.title}</h4>
            <p class={`text-sm leading-relaxed ${
              i === 3 ? 'text-white/70' :
              i === 1 ? 'text-on-primary-container/80' :
              'text-secondary'
            }`}>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-5xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Simple Process</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">How it works.</h2>
      </div>
      <div class="flex flex-col gap-16">
        {steps.map(s => (
          <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start">
            <div class="md:w-1/4 flex-shrink-0">
              <span class="font-headline text-6xl font-extrabold text-outline-variant/40">{s.num}</span>
            </div>
            <div class="md:w-3/4">
              <h4 class="font-headline text-2xl font-bold text-on-surface mb-3">{s.title}</h4>
              <p class="font-body text-secondary leading-relaxed text-lg">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">What Clients Say</span>
        <h2 class="font-headline text-4xl font-extrabold tracking-tighter text-on-surface">Trusted across Malaysia.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`rounded-3xl p-10 flex flex-col justify-between ${i === 1 ? 'bg-primary-container' : 'bg-surface-container-low'}`}>
            <p class={`font-body text-lg leading-relaxed italic mb-8 ${i === 1 ? 'text-on-primary-container' : 'text-on-surface-variant'}`}>
              "{t.quote}"
            </p>
            <div>
              <div class={`h-px mb-4 ${i === 1 ? 'bg-on-primary-container/20' : 'bg-outline-variant/30'}`}></div>
              <p class={`font-headline font-bold ${i === 1 ? 'text-on-primary-container' : 'text-on-surface'}`}>{t.name}</p>
              <p class={`font-body text-sm ${i === 1 ? 'text-on-primary-container/70' : 'text-secondary'}`}>{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== BLOG FEED ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div>
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">From the Blog</span>
          <h2 class="font-headline text-4xl font-extrabold tracking-tighter text-on-surface">Packaging insights.</h2>
        </div>
        <a href="/blog" class="text-primary font-headline font-bold border-b-2 border-primary-container hover:border-primary transition-all pb-1 whitespace-nowrap">All Articles →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Featured post -->
        <article class="md:col-span-8 bg-surface rounded-3xl overflow-hidden group">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={blogPosts[0].img}
              alt={blogPosts[0].title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-2 block">{blogPosts[0].category}</span>
            <h3 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-3 leading-tight">{blogPosts[0].title}</h3>
            <p class="font-body text-secondary text-sm leading-relaxed mb-5">{blogPosts[0].excerpt}</p>
            <a href={`/blog/${blogPosts[0].slug}`} class="inline-flex items-center gap-1 text-primary font-headline font-bold text-sm hover:gap-3 transition-all">
              Read Article <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
            </a>
          </div>
        </article>

        <!-- Side posts -->
        <div class="md:col-span-4 flex flex-col gap-5">
          {blogPosts.slice(1, 3).map(post => (
            <article class="bg-surface rounded-3xl overflow-hidden group flex flex-col flex-1">
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={post.img}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class="p-6 flex flex-col flex-1">
                <span class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-1 block">{post.category}</span>
                <h3 class="font-headline text-lg font-bold tracking-tight text-on-surface mb-2 leading-snug flex-1">{post.title}</h3>
                <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-1 text-primary font-headline font-bold text-xs hover:gap-2 transition-all mt-2">
                  Read <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="py-32 bg-primary-container text-on-primary-container relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
      <span class="material-symbols-outlined" style="font-size:200px;">inventory_2</span>
    </div>
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center relative z-10">
      <h2 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter mb-6">
        Ready to place your first order?
      </h2>
      <p class="font-body text-lg mb-10 opacity-90 max-w-xl mx-auto leading-relaxed">
        Min. order RM 1,000. Fixed wholesale pricing. Delivery across Peninsular Malaysia. No surprises.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/shop" class="bg-on-surface text-surface px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-primary transition-colors duration-200">
          Browse the Shop
        </a>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 bg-[#25D366] text-white px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-[#1ebd5a] transition-colors duration-200">

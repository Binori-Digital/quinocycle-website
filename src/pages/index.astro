---

<Layout>
  <!-- ===================== IMAGE TRAIL HERO ===================== -->
  <section
    id="trailHero"
    class="relative min-h-screen flex items-center overflow-hidden bg-surface select-none"
    style="cursor: none;"
  >
    <!-- Trail images render here (JS-injected) -->
    <div id="trailContainer" class="absolute inset-0 pointer-events-none z-10"></div>

    <!-- Custom cursor dot -->
    <div
      id="trailCursor"
      class="fixed pointer-events-none z-[999] w-3 h-3 rounded-full bg-primary opacity-0 transition-opacity duration-300"
      style="transform: translate(-50%, -50%); top: 0; left: 0;"
    ></div>

    <!-- Subtle grid texture background -->
    <div class="absolute inset-0 z-0 opacity-[0.025]"
      style="background-image: linear-gradient(#1d1c16 1px, transparent 1px), linear-gradient(90deg, #1d1c16 1px, transparent 1px); background-size: 60px 60px;">
    </div>

    <!-- Main content -->
    <div class="relative z-20 w-full max-w-7xl mx-auto px-6 md:px-8 py-24 md:py-32">

      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 bg-primary-container/20 rounded-full border border-primary/15 fade-up">
        <span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>
        <span class="font-label text-xs font-bold uppercase tracking-[0.22em] text-primary">Wholesale Carton Box Supplier · Malaysia</span>
      </div>

      <!-- Headline -->
      <h1 class="font-headline font-black tracking-tighter leading-[0.88] text-on-surface mb-8 fade-up fade-up-1"
          style="font-size: clamp(3.5rem, 10vw, 8.5rem);">
        Box More.<br />
        <span class="text-primary italic">Spend Less.</span>
      </h1>

      <!-- Sub -->
      <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-xl mb-10 leading-relaxed fade-up fade-up-2">
        New &amp; used carton boxes in bulk — fixed wholesale prices,
        Peninsular Malaysia delivery. Trusted by retailers, online sellers,
        movers and logistics companies.
      </p>

      <!-- Meta chips -->
      <div class="flex flex-wrap gap-3 mb-12 fade-up fade-up-3">
        {['Min. Order RM 1,000', 'Fixed Wholesale Pricing', 'Peninsular Malaysia Delivery'].map(chip => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface-container rounded-full border border-outline-variant/40 text-xs font-label font-semibold text-on-surface-variant">
            <span class="material-symbols-outlined text-primary" style="font-size:13px;">check_circle</span>
            {chip}
          </span>
        ))}
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 fade-up fade-up-4">
        <a href="/shop"
           class="bg-primary-container text-on-primary-container px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:opacity-90 transition-all duration-200 pointer-events-auto">
          Browse the Shop
        </a>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-2 bg-[#25D366] text-white px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-[#1ebd5a] transition-colors duration-200 pointer-events-auto">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>

      <!-- Move hint -->
      <p class="mt-16 font-label text-xs uppercase tracking-[0.25em] text-outline flex items-center gap-2 fade-up fade-up-4 pointer-events-none" id="trailHint">
        <span class="inline-block w-6 h-px bg-outline"></span>
        Move your mouse to explore
      </p>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 opacity-40">
      <span class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant">Scroll</span>
      <div class="w-px h-8 bg-on-surface-variant" style="animation: scrollPulse 1.8s ease-in-out infinite;"></div>
    </div>
  </section>

  <style>
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.2; transform: scaleY(1); }
      50%       { opacity: 1;   transform: scaleY(0.6); }
    }
    /* Trail image entry/exit handled by JS inline styles */
    .trail-img {
      position: absolute;
      pointer-events: none;
      border-radius: 16px;
      overflow: hidden;
      will-change: transform, opacity;
      box-shadow: 0 12px 40px rgba(29, 28, 22, 0.18), 0 2px 8px rgba(29, 28, 22, 0.1);
    }
    .trail-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  </style>

  <script define:vars={{ WA_LINK }}>
    (function () {
      const TRAIL_IMAGES = [
        '/images/box-new-s.jpg',
        '/images/box-new-m.jpg',
        '/images/box-new-l.jpg',
        '/images/box-new-xl.jpg',
        '/images/box-used-s.jpg',
        '/images/box-used-m.jpg',
        '/images/box-used-l.jpg',
        '/images/box-used-xl.jpg',
        '/images/audience-retail.jpg',
        '/images/audience-online.jpg',
        '/images/audience-mover.jpg',
        '/images/audience-logistics.jpg',
        '/images/hero-boxes.jpg',
        '/images/product-new.jpg',
        '/images/product-used.jpg',
      ];

      const MIN_DISTANCE   = 90;   // px the cursor must travel before spawning
      const MAX_ON_SCREEN  = 10;   // max simultaneous images
      const LINGER_MS      = 900;  // ms before fade-out starts
      const FADE_MS        = 600;  // fade-out duration

      const hero      = document.getElementById('trailHero');
      const container = document.getElementById('trailContainer');
      const cursor    = document.getElementById('trailCursor');
      const hint      = document.getElementById('trailHint');

      if (!hero || !container) return;

      let imgIndex = 0;
      let lastX = 0;
      let lastY = 0;
      let hasInteracted = false;

      /* ── Custom cursor ── */
      document.addEventListener('mousemove', (e) => {
        cursor.style.left = e.clientX + 'px';
        cursor.style.top  = e.clientY + 'px';
      });

      /* ── Show/hide cursor & hint when entering/leaving hero ── */
      hero.addEventListener('mouseenter', () => {
        cursor.style.opacity = '1';
      });
      hero.addEventListener('mouseleave', () => {
        cursor.style.opacity = '0';
      });

      /* ── Trail logic ── */
      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const dx   = x - lastX;
        const dy   = y - lastY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MIN_DISTANCE) return;

        lastX = x;
        lastY = y;

        /* Hide hint after first interaction */
        if (!hasInteracted) {
          hasInteracted = true;
          if (hint) {
            hint.style.transition = 'opacity 0.5s ease';
            hint.style.opacity = '0';
          }
        }

        /* Cull oldest if over limit */
        const existing = container.querySelectorAll('.trail-img');
        if (existing.length >= MAX_ON_SCREEN) {
          killImage(existing[0]);
        }

        spawnImage(x, y);
      });

      function spawnImage(x, y) {
        const src      = TRAIL_IMAGES[imgIndex % TRAIL_IMAGES.length];
        imgIndex++;

        /* Randomise size & rotation */
        const w        = 130 + Math.random() * 80;        /* 130–210 px */
        const ratio    = 0.7 + Math.random() * 0.45;      /* portrait–landscape */
        const h        = w * ratio;
        const rot      = (Math.random() - 0.5) * 28;      /* ±14 deg */
        const zBase    = 5 + (imgIndex % 8);

        const wrapper  = document.createElement('div');
        wrapper.className = 'trail-img';
        wrapper.style.cssText = [
          `width:${w}px`,
          `height:${h}px`,
          `left:${x}px`,
          `top:${y}px`,
          `z-index:${zBase}`,
          `transform:translate(-50%,-50%) rotate(${rot}deg) scale(0)`,
          `opacity:1`,
          `transition:transform 0.45s cubic-bezier(0.34,1.56,0.64,1)`,
        ].join(';');

        const img = document.createElement('img');
        img.src = src;
        img.alt = '';
        img.loading = 'eager';
        wrapper.appendChild(img);
        container.appendChild(wrapper);

        /* Animate in — double rAF ensures initial style is painted first */
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            wrapper.style.transform = `translate(-50%,-50%) rotate(${rot}deg) scale(1)`;
          });
        });

        /* Schedule fade-out */
        const fadeTimer = setTimeout(() => killImage(wrapper, rot), LINGER_MS);
        wrapper._fadeTimer = fadeTimer;
      }

      function killImage(el, rot) {
        if (!el || !el.parentNode) return;
        clearTimeout(el._fadeTimer);
        const curRot = rot !== undefined ? rot : 0;
        el.style.transition = `transform ${FADE_MS}ms ease, opacity ${FADE_MS}ms ease`;
        el.style.opacity    = '0';
        el.style.transform  = `translate(-50%,-50%) rotate(${curRot * 1.4}deg) scale(0.75)`;
        setTimeout(() => el.remove(), FADE_MS + 50);
      }

      /* ── Touch: no trail, but restore cursor default ── */
      if ('ontouchstart' in window) {
        hero.style.cursor = 'auto';
        cursor.style.display = 'none';
        if (hint) hint.style.display = 'none';
      }
    })();
  </script>

  <!-- ===================== WHO WE SERVE — BENTO GRID ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div class="max-w-xl">
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Who We Serve</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">Packaging for every kind of business.</h2>
        </div>
        <a href="/shop" class="text-primary font-headline font-bold border-b-2 border-primary-container hover:border-primary transition-all pb-1 whitespace-nowrap">Full Catalogue →</a>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-5">
        {audiences.map((a, i) => (
          <div class={`${a.span} bg-surface rounded-3xl overflow-hidden group relative min-h-[340px]`}>
            <div class="absolute inset-0 bg-gradient-to-t from-on-surface/60 via-on-surface/20 to-transparent z-10"></div>
            <img
              src={a.img}
              alt={a.label}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 p-8 z-20">
              <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary-container mb-3 block">{a.label}</span>
              <h3 class="font-headline text-2xl md:text-3xl font-bold text-white mb-3 leading-tight">{a.headline}</h3>
              <p class="text-white/75 text-sm leading-relaxed mb-5 max-w-sm">{a.body}</p>
              <a
                href={a.href}
                target={a.href.startsWith('http') ? '_blank' : undefined}
                rel={a.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="inline-flex bg-primary-container text-on-primary-container px-6 py-2.5 rounded-full font-headline font-bold text-xs uppercase tracking-widest hover:opacity-90 transition-all"
              >
                {a.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== FEATURES ===================== -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Why Quinocycle</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">
          The foundation of <span class="text-primary italic">reliability.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
        {features.map((f, i) => (
          <div class={`rounded-3xl p-8 flex flex-col gap-4 ${
            i === 3 ? 'bg-inverse-surface text-white' :
            i === 1 ? 'bg-primary-container' :
            'bg-surface-container-low'
          }`}>
            <span class={`material-symbols-outlined text-4xl ${
              i === 3 ? 'text-primary-container' :
              'text-primary'
            }`}>{f.icon}</span>
            <h4 class={`font-headline font-bold text-xl ${i === 3 ? 'text-white' : 'text-on-surface'}`}>{f.title}</h4>
            <p class={`text-sm leading-relaxed ${
              i === 3 ? 'text-white/70' :
              i === 1 ? 'text-on-primary-container/80' :
              'text-secondary'
            }`}>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== HOW IT WORKS ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-5xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Simple Process</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">How it works.</h2>
      </div>
      <div class="flex flex-col gap-16">
        {steps.map(s => (
          <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start">
            <div class="md:w-1/4 flex-shrink-0">
              <span class="font-headline text-6xl font-extrabold text-outline-variant/40">{s.num}</span>
            </div>
            <div class="md:w-3/4">
              <h4 class="font-headline text-2xl font-bold text-on-surface mb-3">{s.title}</h4>
              <p class="font-body text-secondary leading-relaxed text-lg">{s.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">What Clients Say</span>
        <h2 class="font-headline text-4xl font-extrabold tracking-tighter text-on-surface">Trusted across Malaysia.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`rounded-3xl p-10 flex flex-col justify-between ${i === 1 ? 'bg-primary-container' : 'bg-surface-container-low'}`}>
            <p class={`font-body text-lg leading-relaxed italic mb-8 ${i === 1 ? 'text-on-primary-container' : 'text-on-surface-variant'}`}>
              "{t.quote}"
            </p>
            <div>
              <div class={`h-px mb-4 ${i === 1 ? 'bg-on-primary-container/20' : 'bg-outline-variant/30'}`}></div>
              <p class={`font-headline font-bold ${i === 1 ? 'text-on-primary-container' : 'text-on-surface'}`}>{t.name}</p>
              <p class={`font-body text-sm ${i === 1 ? 'text-on-primary-container/70' : 'text-secondary'}`}>{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== BLOG FEED ===================== -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div>
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">From the Blog</span>
          <h2 class="font-headline text-4xl font-extrabold tracking-tighter text-on-surface">Packaging insights.</h2>
        </div>
        <a href="/blog" class="text-primary font-headline font-bold border-b-2 border-primary-container hover:border-primary transition-all pb-1 whitespace-nowrap">All Articles →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <!-- Featured post -->
        <article class="md:col-span-8 bg-surface rounded-3xl overflow-hidden group">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={blogPosts[0].img}
              alt={blogPosts[0].title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <div class="p-8">
            <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-2 block">{blogPosts[0].category}</span>
            <h3 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-3 leading-tight">{blogPosts[0].title}</h3>
            <p class="font-body text-secondary text-sm leading-relaxed mb-5">{blogPosts[0].excerpt}</p>
            <a href={`/blog/${blogPosts[0].slug}`} class="inline-flex items-center gap-1 text-primary font-headline font-bold text-sm hover:gap-3 transition-all">
              Read Article <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
            </a>
          </div>
        </article>

        <!-- Side posts -->
        <div class="md:col-span-4 flex flex-col gap-5">
          {blogPosts.slice(1, 3).map(post => (
            <article class="bg-surface rounded-3xl overflow-hidden group flex flex-col flex-1">
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={post.img}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class="p-6 flex flex-col flex-1">
                <span class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-1 block">{post.category}</span>
                <h3 class="font-headline text-lg font-bold tracking-tight text-on-surface mb-2 leading-snug flex-1">{post.title}</h3>
                <a href={`/blog/${post.slug}`} class="inline-flex items-center gap-1 text-primary font-headline font-bold text-xs hover:gap-2 transition-all mt-2">
                  Read <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA ===================== -->
  <section class="py-32 bg-primary-container text-on-primary-container relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
      <span class="material-symbols-outlined" style="font-size:200px;">inventory_2</span>
    </div>
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center relative z-10">
      <h2 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter mb-6">
        Ready to place your first order?
      </h2>
      <p class="font-body text-lg mb-10 opacity-90 max-w-xl mx-auto leading-relaxed">
        Min. order RM 1,000. Fixed wholesale pricing. Delivery across Peninsular Malaysia. No surprises.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/shop" class="bg-on-surface text-surface px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-primary transition-colors duration-200">
          Browse the Shop
        </a>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 bg-[#25D366] text-white px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-[#1ebd5a] transition-colors duration-200">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us

---
import Layout from '../layouts/Layout.astro';
const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20would%20like%20to%20know%20more%20about%20your%20business.';
---

<Layout
  title="About Quinocycle — Malaysia's Wholesale Carton Box Supplier"
  description="Quinocycle supplies new and used carton boxes in bulk to businesses across Peninsular Malaysia. Fixed wholesale pricing. Free delivery across KL & Selangor for orders above RM300."
>
  <!-- Hero -->
  <section class="pt-16 pb-24 px-6 md:px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-7">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">About Us</span>
        <h1 class="font-headline text-6xl md:text-7xl font-extrabold tracking-tighter text-on-surface leading-[0.9] mb-8">
          We make bulk<br /><span class="text-primary italic">buying simple.</span>
        </h1>
        <p class="font-body text-xl text-secondary max-w-lg leading-relaxed">
          Malaysia's most reliable wholesale carton box supplier — fixed prices, no surprises, delivered across Peninsular Malaysia.
        </p>
      </div>
      <div class="lg:col-span-5 lg:text-right">
        <div class="inline-flex flex-col items-start lg:items-end">
          <span class="text-4xl font-headline font-bold text-primary-container opacity-50 mb-2">EST. 2020</span>
          <div class="h-px w-32 bg-outline-variant/30 mb-4"></div>
          <p class="font-label text-[10px] uppercase tracking-widest text-outline">Built to fix Malaysia's packaging supply problem</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <!-- Image side -->
        <div class="relative">
          <div class="bg-surface p-3 rounded-[2.5rem] rotate-2 editorial-shadow inline-block">
            <img
              src="/images/audience-retail.jpg"
              alt="Quinocycle warehouse"
              class="rounded-[2rem] w-full max-w-md h-[480px] object-cover"
            />
          </div>
          <div class="absolute -bottom-8 -right-4 md:-right-8 bg-primary-container p-8 rounded-[2rem] max-w-xs editorial-shadow -rotate-2">
            <h5 class="font-headline font-bold text-xl mb-2 text-on-primary-container">Fixed Wholesale Pricing</h5>
            <p class="text-on-primary-container/80 text-sm leading-relaxed">No hidden fees. No "call for price". Our rates are published and consistent for every order.</p>
          </div>
        </div>

        <!-- Text side -->
        <div class="lg:pl-8">
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">Our Story</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-8 leading-[1.1]">
            Born from a simple <br /><span class="text-primary italic">frustration.</span>
          </h2>
          <div class="space-y-5 text-on-surface-variant font-body leading-loose text-lg">
            <p>Malaysian businesses were spending too much on packaging — either paying retail prices for boxes, or struggling to find a reliable bulk supplier with transparent pricing.</p>
            <p>Quinocycle was built to fix that. We source new and used carton boxes in volume and sell them at fixed wholesale prices — with free delivery across KL &amp; Selangor for orders above RM300.</p>
            <p>We serve retailers, online sellers, mover companies, and logistics businesses across Peninsular Malaysia. Our goal: make packaging less of a problem and more of a solved thing.</p>
          </div>
          <div class="mt-10 pt-8 border-t border-outline-variant/20 flex items-center gap-4">
            <div class="h-px flex-1 bg-outline-variant/20"></div>
            <span class="text-primary font-headline font-bold italic text-sm">Quinocycle · Malaysia</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center">
        {[
          { num: '500+',  label: 'Businesses Served' },
          { num: '2×',    label: 'Product Lines (New & Used)' },
          { num: 'RM1k',  label: 'Min. Order — Transparent & Fixed' },
          { num: '100%',  label: 'Peninsular Malaysia Coverage' },
        ].map(s => (
          <div class="flex flex-col items-center">
            <span class="font-headline text-5xl md:text-6xl font-black text-primary mb-3">{s.num}</span>
            <p class="font-label text-xs uppercase tracking-widest text-secondary text-center leading-relaxed">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values — Bento Grid -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-16">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">What We Stand For</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface max-w-2xl">
          Three things we never compromise on.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <!-- Card 1 -->
        <div class="md:col-span-2 bg-surface-container p-10 rounded-3xl flex flex-col justify-between group overflow-hidden relative min-h-[280px]">
          <div class="relative z-10">
            <span class="material-symbols-outlined text-primary text-4xl mb-5 block">paid</span>
            <div class="font-headline text-5xl font-black text-outline-variant/20 absolute top-8 right-8">01</div>
            <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Pricing Transparency</h3>
            <p class="font-body text-secondary leading-relaxed max-w-md">No hidden fees. No "call for price". Our fixed wholesale rates are published and consistent. You know exactly what you're paying before you order.</p>
          </div>
          <div class="absolute right-0 bottom-0 opacity-5 group-hover:scale-110 transition-transform duration-700 pointer-events-none">
            <span class="material-symbols-outlined" style="font-size:180px;">receipt_long</span>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-primary-container p-10 rounded-3xl flex flex-col justify-between relative overflow-hidden min-h-[280px]">
          <div>
            <span class="material-symbols-outlined text-on-primary-container text-4xl mb-5 block">inventory_2</span>
            <div class="font-headline text-5xl font-black text-on-primary-container/10 absolute top-8 right-8">02</div>
            <h3 class="font-headline text-2xl font-bold text-on-primary-container mb-4">Reliable Supply</h3>
            <p class="text-on-primary-container/80 leading-relaxed font-body">When you depend on us for packaging, we show up. We maintain stock to ensure orders are fulfilled without surprise delays.</p>
          </div>
        </div>

        <!-- Card 3 — dark -->
        <div class="bg-inverse-surface p-10 rounded-3xl flex flex-col justify-between relative overflow-hidden min-h-[280px]">
          <div>
            <span class="material-symbols-outlined text-primary-container text-4xl mb-5 block">recycling</span>
            <div class="font-headline text-5xl font-black text-white/5 absolute top-8 right-8">03</div>
            <h3 class="font-headline text-2xl font-bold text-white mb-4">Sustainability First</h3>
            <p class="text-white/70 leading-relaxed font-body">Our used box programme gives quality packaging a second life. Less waste, lower costs — good for business, good for the environment.</p>
          </div>
        </div>

        <!-- Wide image card -->
        <div class="md:col-span-2 relative aspect-[21/9] rounded-3xl overflow-hidden group">
          <img
            src="/images/audience-logistics.jpg"
            alt="Quinocycle logistics"
            class="w-full h-full object-cover brightness-75 group-hover:scale-105 transition-transform duration-1000"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-on-surface/60 to-transparent flex items-end p-10">
            <p class="text-white text-xl font-headline italic">"Packaging shouldn't be a problem. We make it a solved thing." — Quinocycle</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-primary-container text-on-primary-container relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-10 pointer-events-none">
      <span class="material-symbols-outlined" style="font-size:200px;">package_2</span>
    </div>
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center relative z-10">
      <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter mb-6">
        Ready to place your first order?
      </h2>
      <p class="font-body text-lg mb-10 opacity-90 max-w-xl mx-auto">
        Free delivery across KL &amp; Selangor (for orders above RM300). Fixed wholesale pricing. Delivery across Peninsular Malaysia.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/shop" class="bg-on-surface text-surface px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-primary transition-colors">
          Browse the Shop
        </a>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 bg-[#25D366] text-white px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-[#1ebd5a] transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>
</Layout>

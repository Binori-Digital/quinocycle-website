---
import Layout from '../layouts/Layout.astro';
const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20would%20like%20to%20know%20more%20about%20your%20business.';
---

<Layout
  title="About Quinocycle — Malaysia's Wholesale Carton Box Supplier"
  description="Quinocycle supplies new and used carton boxes in bulk to businesses across Peninsular Malaysia. Fixed wholesale pricing, min. order RM1,000."
>
  <section class="about-hero">
    <div class="container">
      <div class="section-eyebrow" style="color:rgba(255,255,255,0.5)">About Us</div>
      <h1 class="about-hero__title">We make bulk<br /><span>buying simple.</span></h1>
    </div>
  </section>

  <section class="about-body">
    <div class="container about-body__inner">

      <div class="about-story">
        <div class="section-eyebrow">Our Story</div>
        <h2 class="about-story__title">Born from a simple frustration.</h2>
        <div class="about-story__text">
          <p>Malaysian businesses were spending too much on packaging — either paying retail prices for boxes, or struggling to find a reliable bulk supplier with transparent pricing.</p>
          <p>Quinocycle was built to fix that. We source new and used carton boxes in volume and sell them at fixed wholesale prices, with no minimum order complexity — just a straightforward RM 1,000 minimum to keep supply sustainable for everyone.</p>
          <p>We serve retailers, online sellers, mover companies, and logistics businesses across Peninsular Malaysia. Our goal is simple: make packaging less of a problem and more of a solved thing.</p>
        </div>
      </div>

      <div class="about-stats">
        <div class="about-stat">
          <div class="about-stat__num">500<span>+</span></div>
          <div class="about-stat__label">Businesses Served</div>
        </div>
        <div class="about-stat">
          <div class="about-stat__num">2<span>×</span></div>
          <div class="about-stat__label">Product Lines<br />(New & Used)</div>
        </div>
        <div class="about-stat">
          <div class="about-stat__num">RM1k</div>
          <div class="about-stat__label">Min. Order<br />Transparent & Fixed</div>
        </div>
        <div class="about-stat">
          <div class="about-stat__num">100<span>%</span></div>
          <div class="about-stat__label">Peninsular Malaysia<br />Delivery Coverage</div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-values">
    <div class="container">
      <div class="section-eyebrow">What We Stand For</div>
      <h2 class="about-values__title">Three things we never compromise on.</h2>
      <div class="about-values__grid">
        <div class="value-card">
          <div class="value-card__num">01</div>
          <h3 class="value-card__title">Pricing Transparency</h3>
          <p class="value-card__body">No hidden fees. No "call for price". Our fixed wholesale rates are published and consistent. You know exactly what you're paying before you order.</p>
        </div>
        <div class="value-card">
          <div class="value-card__num">02</div>
          <h3 class="value-card__title">Reliable Supply</h3>
          <p class="value-card__body">When you depend on us for packaging, we show up. We maintain stock levels to ensure your orders can be fulfilled without surprise delays.</p>
        </div>
        <div class="value-card">
          <div class="value-card__num">03</div>
          <h3 class="value-card__title">Sustainability First</h3>
          <p class="value-card__body">Our used box programme gives quality packaging a second life. Less waste, lower costs for buyers — good for business, good for the environment.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta">
    <div class="container about-cta__inner">
      <h2 class="about-cta__title">Ready to place your first order?</h2>
      <div class="about-cta__btns">
        <a href="/shop" class="btn btn-primary btn-lg">Browse the Shop</a>
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">WhatsApp Us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.about-hero {
  background: var(--black);
  padding-block: clamp(3rem, 6vw, 5rem);
}
.about-hero__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--white);
  margin-block: 1rem;
}
.about-hero__title span { color: var(--yellow); }

.about-body { padding-block: var(--section-py); }
.about-body__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}
@media (max-width: 900px) {
  .about-body__inner { grid-template-columns: 1fr; gap: 3rem; }
}

.about-story__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.75rem, 3vw, 2.75rem);
  line-height: 1.1;
  margin-block: 0.75rem 1.5rem;
}
.about-story__text {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.about-story__text p {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--grey-600);
}

.about-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.about-stat {
  padding: 2rem 1.5rem;
  background: var(--grey-50);
  border: 1.5px solid var(--grey-200);
  border-radius: var(--radius-md);
  border-left: 4px solid var(--yellow);
}
.about-stat__num {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 3rem;
  line-height: 1;
  color: var(--black);
  margin-bottom: 0.5rem;
}
.about-stat__num span { color: var(--yellow); }
.about-stat__label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--grey-600);
  line-height: 1.5;
}

.about-values {
  background: var(--yellow);
  padding-block: var(--section-py);
}
.about-values__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(1.75rem, 3.5vw, 3rem);
  line-height: 1.1;
  color: var(--black);
  margin-block: 0.75rem 3rem;
  max-width: 500px;
}
.about-values__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
@media (max-width: 900px) { .about-values__grid { grid-template-columns: 1fr; } }

.value-card {
  background: var(--white);
  border: 2px solid var(--black);
  border-radius: var(--radius-md);
  padding: 2rem;
  box-shadow: 5px 5px 0 var(--black);
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: transform 0.2s var(--ease-out-expo), box-shadow 0.2s;
}
.value-card:hover {
  transform: translate(-3px, -3px);
  box-shadow: 8px 8px 0 var(--black);
}
.value-card__num {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 2.5rem;
  line-height: 1;
  color: var(--yellow);
  -webkit-text-stroke: 2px var(--black);
}
.value-card__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.25rem;
  color: var(--black);
}
.value-card__body {
  font-size: 0.875rem;
  line-height: 1.65;
  color: var(--grey-600);
}

.about-cta {
  background: var(--black);
  padding-block: clamp(3rem, 6vw, 5rem);
}
.about-cta__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 2rem;
}
.about-cta__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1.1;
  color: var(--white);
}
.about-cta__btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
</style>

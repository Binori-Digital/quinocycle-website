      </p>
      <a href={WA_LINK} class="inline-flex items-center gap-2 bg-primary text-on-primary font-label font-bold text-sm uppercase tracking-widest px-6 py-3 rounded-full hover:bg-primary/90 transition-colors">
        Pesan Sekarang
      </a>
    </div>
  </article>
</Layout>

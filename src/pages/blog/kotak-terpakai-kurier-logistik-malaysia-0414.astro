---
import Layout from '../../layouts/Layout.astro';
const post = { title: 'Kotak Terpakai untuk Perkhidmatan Kurier & Logistik — Jimat 40% Kos di Malaysia', description: 'Perkhidmatan kurier dan logistik boleh jimat 40–50% dengan menggunakan kotak kardus terpakai berkualiti. Panduan penyeluruhan untuk operasi logistik berskala besar.', date: '2026-04-14', readTime: '7 min', category: 'Kotak Kardus Terpakai', author: 'Quinocycle Team', slug: 'kotak-terpakai-kurier-logistik-malaysia-0414' };
const WA_LINK = 'https://wa.me/60168916381?text=Hai%20Quinocycle!%20Kami%20menjalankan%20perkhidmatan%20kurier%20dan%20perlukan%20kotak%20terpakai.%20Boleh%20berikan%20harga?';
const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-14', dateModified: '2026-04-14', inLanguage: "ms-MY", author: { "@type": "Organization", name: "Quinocycle Team", url: "https://www.quinocycle.com.my" }, publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my", logo: { "@type": "ImageObject", url: "https://www.quinocycle.com.my/logo.png" } }, mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my" }, keywords: "kotak terpakai, kurier, logistik, jimat kos, pembungkusan borong Malaysia" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Adakah kotak terpakai selamat untuk pengiriman?","acceptedAnswer":{"@type":"Answer","text":"Ya, jika bersumber dengan betul. Quinocycle memeriksa setiap kotak untuk integriti struktur, kerosakan kelembapan, dan kebersihan. Kotak yang gagal ujian ditolak."}},{"@type":"Question","name":"Berapa banyak yang boleh jimat dengan kotak terpakai?","acceptedAnswer":{"@type":"Answer","text":"Biasanya 40–50% kurang kos daripada kotak baru. Sebuah perkhidmatan kurier yang menghantarkan 5,000 paket bulanan boleh jimat RM 5,000–10,000 setiap bulan."}},{"@type":"Question","name":"Adakah kotak terpakai menjejaskan imej jenama?","acceptedAnswer":{"@type":"Answer","text":"Untuk operasi kurier B2B, tidak. Kebanyakan kotak terpakai kelihatan hampir seperti baru. Untuk penghantaran pelanggan akhir, gunakan kotak baru; untuk dalam-gudang, gunakan terpakai."}},{"@type":"Question","name":"Boleh Quinocycle membekalkan jumlah konsisten setiap bulan?","acceptedAnswer":{"@type":"Answer","text":"Ya. Kami mengekalkan bekalan tetap daripada rakan kilang dan gudang. Pesanan suku tahunan dengan jadual penghantaran fleksibel tersedia."}},{"@type":"Question","name":"Bagaimana proses jaminan kualiti Quinocycle?","acceptedAnswer":{"@type":"Answer","text":"Setiap batch diperiksa untuk integriti dinding, kerosakan kelembapan, dan pencemaran. Kotak yang gagal ujian struktural ditolak. Kami hanya membekal kotak terpakai berkualiti tinggi."}}]};
const localBusinessSchema = { "@context":"https://schema.org","@type":"Store", name:"Quinocycle Sdn. Bhd.", url:"https://www.quinocycle.com.my", telephone:"+60168916381", address:{"@type":"PostalAddress","streetAddress":"No.13, Jalan Taming P/1, Taming Jaya","addressLocality":"Balakong","addressRegion":"Selangor","postalCode":"43300","addressCountry":"MY"}, geo:{"@type":"GeoCoordinates","latitude":3.0579,"longitude":101.7468}, openingHoursSpecification:[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"18:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"09:00","closes":"13:00"}], priceRange:"RM 0.90 – RM 3.50 setiap kotak", areaServed:"Semenanjung Malaysia" };
---
<Layout title={post.title} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <article class="max-w-4xl mx-auto px-6 md:px-8 pt-16 pb-24">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-primary/20 text-primary font-label font-bold text-xs uppercase tracking-widest px-3 py-1 rounded-full">{post.category}</span>
        <time class="font-body text-sm text-secondary">{post.date}</time>
      </div>
      <h1 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-4">{post.title}</h1>
      <p class="font-body text-lg text-secondary leading-relaxed">{post.description}</p>
    </header>

    <section class="mb-12">
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Bagi perkhidmatan kurier dan logistik beroperasi di Malaysia, kos pembungkusan adalah salah satu perbelanjaan operasi terbesar. Peralihan kepada kotak kardus terpakai berkualiti boleh mengurangkan kos sebanyak 40–50% tanpa menjejaskan keselamatan produk.

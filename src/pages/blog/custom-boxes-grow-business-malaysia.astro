const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much more expensive are custom boxes compared to plain boxes?", "acceptedAnswer": { "@type": "Answer", "text": "Custom boxes typically cost 20-50% more than plain boxes, depending on design complexity and order quantity. A plain box might cost RM 2 per unit, while a custom branded box costs RM 2.50-3.50 per unit. However, the return on investment through increased sales, brand recognition, and customer loyalty often justifies the higher cost within 3-6 months." } },
    { "@type": "Question", "name": "What is the minimum order for custom branded boxes in Malaysia?", "acceptedAnswer": { "@type": "Answer", "text": "Most Malaysian custom box suppliers require minimum orders of 1,000-5,000 units for custom designs. For businesses starting out, ordering 1,000 custom boxes provides enough inventory for 3-6 months while allowing you to test the market. Larger quantities (5,000+) significantly reduce per-unit cost, making them economical for established businesses." } },
    { "@type": "Question", "name": "How does custom packaging affect customer satisfaction and repeat purchases?", "acceptedAnswer": { "@type": "Answer", "text": "Studies show custom branded packaging increases customer satisfaction by 35-50% and repeat purchase rates by 25-40%. Memorable unboxing experiences create shareable moments on social media, generating free marketing. Customers perceive higher product value when it arrives in branded packaging, justifying premium pricing and building brand loyalty over time." } },
    { "@type": "Question", "name": "What elements should I include in custom box design?", "acceptedAnswer": { "@type": "Answer", "text": "Essential elements include: company logo, brand colors, product information, usage instructions, your website/social media, and contact information. Include a thank-you message to personalize the experience. Avoid cluttering—clean, professional design is more impactful than busy layouts. Include QR codes linking to your website, product reviews, or social media for added engagement." } },
    { "@type": "Question", "name": "How long does custom box production take in Malaysia?", "acceptedAnswer": { "@type": "Answer", "text": "Custom box production typically takes 2-4 weeks from design approval to delivery, depending on supplier workload and complexity. Standard production is 3 weeks. Rush orders may be available at premium cost (typically 30-50% surcharge) with 1-2 week turnaround. Always allow extra lead time to avoid stock shortages affecting sales." } }

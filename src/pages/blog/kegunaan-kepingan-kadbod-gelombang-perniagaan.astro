const post = {
  title: '10 Cara Perniagaan Malaysia Guna Kepingan Kadbod Gelombang untuk Pembungkusan',
  description: 'Temukan 10 kegunaan kreatif kepingan kadbod gelombang untuk pembungkusan perniagaan. Dari perlindungan fragile hingga pengganjal produk, tingkatkan kualiti pembungkusan dengan harga terjangkau.',

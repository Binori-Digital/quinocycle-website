const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-15', dateModified: '2026-04-15', inLanguage:"en-MY", author:{name:"Quinocycle Team",url:"https://www.quinocycle.com.my"}, publisher:{name:"Quinocycle Sdn. Bhd.",logo:{url:"https://www.quinocycle.com.my/logo.png"}}, mainEntityOfPage:{url:"https://www.quinocycle.com.my/blog/corrugated-cardboard-glassware-ceramics-protection-0415"}, keywords:"corrugated cardboard protection, glassware protection, ceramic packing, divider sheets Malaysia, fragile item shipping, bubble wrap alternatives, Balakong Selangor" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What thickness of cardboard is best for protecting glassware?","acceptedAnswer":{"@type":"Answer","text":"3mm to 5mm corrugated sheets provide good cushioning. Use multiple layers (typically 2–3 sheets) between delicate items for optimal protection during transport."}},{"@type":"Question","name":"Can corrugated cardboard replace bubble wrap?","acceptedAnswer":{"@type":"Answer","text":"Yes, partially. Cardboard dividers prevent item-to-item contact; bubble wrap provides impact cushioning. Ideally, combine both: cardboard dividers + bubble wrap on fragile items."}},{"@type":"Question","name":"How should I arrange cardboard layers for wine glasses?","acceptedAnswer":{"@type":"Answer","text":"Place one corrugated sheet per layer of glasses, with bubble wrap around each stem. Stack layers no more than 3–4 high. This prevents shifting and impact damage."}},{"@type":"Question","name":"Is corrugated cardboard moisture-resistant?","acceptedAnswer":{"@type":"Answer","text":"Standard corrugated is not moisture-proof. For water-sensitive ceramics or overseas shipping, use wax-coated or plastic-backed corrugated sheets to prevent moisture absorption."}},{"@type":"Question","name":"What's the cost difference between cardboard dividers and bubble wrap?","acceptedAnswer":{"@type":"Answer","text":"Corrugated sheets: RM 0.20–0.50 per sheet. Bubble wrap: RM 0.10–0.25 per meter. Using cardboard dividers reduces overall protective material costs while providing structural separation."}}]};

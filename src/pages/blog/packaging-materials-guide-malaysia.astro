  description: 'Complete guide to 7 essential packaging materials: costs, best uses, combinations. Help Malaysian businesses choose the right materials for their needs.',
  date: '2026-04-11',
  readTime: '10 min',
  category: 'Packaging Knowledge',
  author: 'Quinocycle Team',
  slug: 'packaging-materials-guide-malaysia',
};

const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20need%20help%20choosing%20the%20right%20packaging%20materials%20for%20my%20business.';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,

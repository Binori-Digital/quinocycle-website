const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are the 7 most essential packaging materials?", "acceptedAnswer": { "@type": "Answer", "text": "The 7 essential packaging materials are: corrugated boxes, bubble wrap, stretch film, strapping tape, foam sheets, honeycomb cardboard, and brown kraft tape. These cover 95% of packaging needs for most businesses." } },
    { "@type": "Question", "name": "Which packaging material is most cost-effective?", "acceptedAnswer": { "@type": "Answer", "text": "Kraft paper and corrugated cardboard are most cost-effective per unit. However, total cost depends on application. Using the right material prevents damage, reducing returns. A slightly more expensive material that prevents 5% more damage is more economical overall." } },
    { "@type": "Question", "name": "How do I choose the right packaging material combination?", "acceptedAnswer": { "@type": "Answer", "text": "Consider three factors: item fragility, weight, and handling environment. Start with a sturdy box (corrugated cardboard), add protection based on fragility (bubble wrap for delicate items, honeycomb for heavy items), and seal with appropriate tape. Test with sample shipments." } },
    { "@type": "Question", "name": "Are eco-friendly packaging materials available in Malaysia?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Cardboard, kraft paper, and honeycomb are 100% recyclable and biodegradable. Bubble wrap is recyclable through specialized programs. Avoid plastic-based materials when possible. Quinocycle prioritizes eco-friendly options." } },
    { "@type": "Question", "name": "Where can I buy all packaging materials in bulk?", "acceptedAnswer": { "@type": "Answer", "text": "Quinocycle is a one-stop supplier for all 7 essential packaging materials. Buy everything from one source, negotiate volume discounts, simplify inventory management, and ensure consistent quality across all materials." } }
  ]

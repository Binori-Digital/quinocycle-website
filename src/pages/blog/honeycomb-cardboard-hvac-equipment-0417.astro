const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Can honeycomb cardboard protect heavy HVAC equipment?","acceptedAnswer":{"@type":"Answer","text":"Yes. Thick honeycomb (25–50mm) combined with corrugated outer layers provides excellent shock absorption for AC units, compressors, and mechanical equipment. Use double-walled construction for maximum protection."}},{"@type":"Question","name":"What's the weight capacity of honeycomb cardboard for industrial shipping?","acceptedAnswer":{"@type":"Answer","text":"Honeycomb's capacity depends on thickness and layer design. 25–50mm honeycomb supports 50–100kg equipment weights. For heavier machinery, use reinforced triple-layer honeycomb construction with strapping and bracing."}},{"@type":"Question","name":"How do I prevent vibration damage to HVAC systems during transport?","acceptedAnswer":{"@type":"Answer","text":"Layer honeycomb padding on all equipment sides. Add anti-vibration foam or rubber dampeners. Secure equipment with strapping and bracing inside boxes. Test cushioning with test drops before shipping expensive units."}},{"@type":"Question","name":"Is honeycomb suitable for long-distance HVAC shipping?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Honeycomb's lightweight yet strong protection is ideal for long-haul shipping across Malaysia. Reduces shipping costs compared to foam while providing superior impact resistance during highway transport."}},{"@type":"Question","name":"Where can I order bulk honeycomb for industrial equipment packaging?","acceptedAnswer":{"@type":"Answer","text":"Quinocycle in Balakong supplies industrial-grade honeycomb for machinery and HVAC shipping. Minimum order RM 1,000. Custom thicknesses and sizes available for industrial clients across Malaysia."}}]};
const localBusinessSchema = { "@context":"https://schema.org","@type":"Store", name:"Quinocycle Sdn. Bhd.", url:"https://www.quinocycle.com.my", telephone:"+60168916381", address:{streetAddress:"No.13, Jalan Taming P/1, Taming Jaya", addressLocality:"Balakong", addressRegion:"Selangor", postalCode:"43300", addressCountry:"MY"}, geo:{latitude:3.0579,longitude:101.7468}, openingHoursSpecification:[{dayOfWeek:["Monday","Tuesday","Wednesday","Thursday","Friday"],opens:"09:00",closes:"18:00"},{dayOfWeek:"Saturday",opens:"09:00",closes:"13:00"}], priceRange:"RM 1.90 – RM 6.50 per box", areaServed:"Peninsular Malaysia" };
---
<Layout title={post.title} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <article class="max-w-4xl mx-auto px-6 md:px-8 pt-16 pb-24">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-primary/20 text-primary font-label font-bold text-xs uppercase tracking-widest px-3 py-1 rounded-full">{post.category}</span>
        <time class="font-body text-sm text-secondary">{post.date}</time>

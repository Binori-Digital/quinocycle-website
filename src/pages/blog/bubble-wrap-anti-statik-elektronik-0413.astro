          </div>
          <div class="grid grid-cols-3 gap-2 py-1">
            <span class="text-secondary">Kabel & aksesori</span><span class="text-on-surface">Standard</span><span class="text-on-surface">Kecil (10mm)</span>
          </div>
        </div>

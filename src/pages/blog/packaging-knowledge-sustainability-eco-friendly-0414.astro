const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-14', dateModified: '2026-04-14', inLanguage: "en-MY", author: { "@type": "Organization", name: "Quinocycle Team", url: "https://www.quinocycle.com.my" }, publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my", logo: { "@type": "ImageObject", url: "https://www.quinocycle.com.my/logo.png" } }, mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my" }, keywords: "sustainable packaging, eco-friendly packaging Malaysia, recyclable cartons, green packaging, environmental packaging solutions" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is eco-friendly packaging more expensive than traditional packaging?","acceptedAnswer":{"@type":"Answer","text":"Not necessarily. While some eco-friendly options cost slightly more upfront, they often reduce waste disposal costs and appeal to environmentally conscious customers, offsetting the difference."}},{"@type":"Question","name":"What are the most sustainable packaging materials?","acceptedAnswer":{"@type":"Answer","text":"Corrugated cardboard (100% recyclable), kraft paper, biodegradable bubble wrap, and mushroom-based padding are among the most sustainable options for Malaysian businesses."}},{"@type":"Question","name":"Can used carton boxes be considered eco-friendly?","acceptedAnswer":{"@type":"Answer","text":"Yes! Reusing carton boxes extends their life and reduces waste, making them one of the most environmentally friendly options available. Quinocycle specializes in quality used boxes."}},{"@type":"Question","name":"How can I reduce packaging waste in my business?","acceptedAnswer":{"@type":"Answer","text":"Use right-sized boxes to minimize excess space, eliminate unnecessary padding, switch to reusable packaging where possible, and partner with suppliers who offer sustainable materials."}},{"@type":"Question","name":"Do Malaysian customers care about sustainable packaging?","acceptedAnswer":{"@type":"Answer","text":"Yes. Surveys show 70%+ of Malaysian consumers prefer eco-friendly businesses. Sustainable packaging is now a competitive advantage for e-commerce and F&B businesses."}}]};

const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20Saya%20nak%20optimumkan%20saiz%20kotak%20untuk%20kurangkan%20kos%20DIM%20weight.';
const articleSchema = { "@context":"https://schema.org","@type":"Article","headline":post.title,"description":post.description,"datePublished":post.date,"author":{"@type":"Organization","name":"Quinocycle Sdn. Bhd."},"publisher":{"@type":"Organization","name":"Quinocycle Sdn. Bhd.","logo":{"@type":"ImageObject","url":"https://quinocycle.com.my/logo.png"}},"inLanguage":"ms-MY" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[
  {"@type":"Question","name":"Apa itu berat dimensi (DIM weight)?","acceptedAnswer":{"@type":"Answer","text":"Berat dimensi ialah berat teori yang dikira berdasarkan isipadu bungkusan (P x L x T / faktor kurier). Kurier akan caj mengikut mana-mana lebih tinggi — berat sebenar atau berat dimensi."}},

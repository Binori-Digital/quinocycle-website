const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "What packaging do night market vendors in Malaysia typically need?", acceptedAnswer: { "@type": "Answer", text: "Night market and bazaar vendors commonly need: small carton boxes (for packaged goods), plastic bags, paper bags, food-grade containers (for F&B stalls), bubble wrap (for fragile craft and hobby goods), and packing tape. F&B vendors additionally need takeaway containers, but carton boxes are needed by virtually every type of vendor." } },
    { "@type": "Question", name: "How can I find night market vendors to supply packaging to?", acceptedAnswer: { "@type": "Answer", text: "Start by visiting active night markets in your area (Klang Valley has major ones in Cheras, Subang, Kajang, and Shah Alam). Speak directly to vendors about their packaging needs and where they currently source. Many buy retail at higher prices due to lack of time or knowledge of wholesale suppliers — that is your opportunity." } },
    { "@type": "Question", name: "What margin can I make reselling carton boxes to small vendors?", acceptedAnswer: { "@type": "Answer", text: "Buying wholesale from Quinocycle at RM 1.90–6.50 per box and selling to small traders at RM 3.00–10.00 per box is typical. Margins of 30–60% are achievable when serving small vendors who cannot meet wholesale minimums themselves." } },
    { "@type": "Question", name: "Do I need a business registration to become a packaging reseller?", acceptedAnswer: { "@type": "Answer", text: "For informal reselling, some people start without registration. However, to issue invoices, open business bank accounts, and scale properly, an SSM registration as an enterprise or Sdn Bhd is recommended. Registration costs are low in Malaysia and protects you legally." } },
    { "@type": "Question", name: "Can I buy wholesale packaging from Quinocycle to resell?", acceptedAnswer: { "@type": "Answer", text: "Yes. Quinocycle welcomes packaging resellers. Our wholesale pricing starts from a minimum order of RM 1,000. We can supply consistent stock of carton boxes, bubble wrap, tape, and other packaging materials that resellers can then sell to their end customers at a profit." } },
  ]
};
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  name: "Quinocycle Sdn. Bhd.",
  url: "https://www.quinocycle.com.my",
  telephone: "+60168916381",
  address: { "@type": "PostalAddress", streetAddress: "No.13, Jalan Taming P/1, Taming Jaya", addressLocality: "Balakong", addressRegion: "Selangor", postalCode: "43300", addressCountry: "MY" },
  geo: { "@type": "GeoCoordinates", latitude: 3.0579, longitude: 101.7468 },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "09:00", closes: "18:00" },

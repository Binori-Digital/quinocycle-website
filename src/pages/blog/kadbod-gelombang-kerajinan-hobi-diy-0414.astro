---
import Layout from '../../layouts/Layout.astro';
const post = { title: 'Kadbod Gelombang untuk Kerajinan Tangan & Hobi — Bekalan DIY Borong Malaysia', description: 'Pembuat, artis, dan penggemar kerajinan tangan boleh memperoleh kepingan kadbod gelombang borong untuk projek DIY. Panduan lengkap dan sumber dari Quinocycle Balakong.', date: '2026-04-14', readTime: '7 min', category: 'Kadbod Gelombang', author: 'Quinocycle Team', slug: 'kadbod-gelombang-kerajinan-hobi-diy-0414' };
const WA_LINK = 'https://wa.me/60168916381?text=Hai%20Quinocycle!%20Saya%20pembuat%20dan%20perlukan%20kadbod%20gelombang%20untuk%20projek%20kerajinan.%20Berapa%20harga%20borong?';
const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-14', dateModified: '2026-04-14', inLanguage: "ms-MY", author: { "@type": "Organization", name: "Quinocycle Team", url: "https://www.quinocycle.com.my" }, publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my" }, mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my" }, keywords: "kadbod gelombang, kerajinan DIY, projek seni, harga borong Malaysia" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Berapa ketebalan kadbod gelombang untuk DIY?","acceptedAnswer":{"@type":"Answer","text":"Untuk projek kerajinan, 3–5mm dinding tunggal cukup. Untuk projek struktural (perabot, instalasi besar), 7–10mm dinding berganda lebih sesuai."}},{"@type":"Question","name":"Boleh kadbod gelombang dicat dan dihias?","acceptedAnswer":{"@type":"Answer","text":"Ya! Kadbod menerima cat, penanda, stiker, dan gam dengan mudah. Cat akril berfungsi terbaik. Tiada perlukan primer."}},{"@type":"Question","name":"Berapa kos kadbod gelombang borong di Malaysia?","acceptedAnswer":{"@type":"Answer","text":"Kepingan kadbod biasanya RM 1.50–4.00 setiap kepingan bergantung pada saiz dan gred dinding. Pesanan 100+ kepingan dapat diskaun 10–20%."}},{"@type":"Question","name":"Saiz apa yang Quinocycle tawarkan?","acceptedAnswer":{"@type":"Answer","text":"Kami menawarkan saiz standard dari 60×60cm hingga 120×150cm, dengan pemotongan khas tersedia. Kepingan boleh ditumpuk rata untuk penghantaran atau dihantar di palet."}},{"@type":"Question","name":"Adakah kadbod gelombang mesra alam?","acceptedAnswer":{"@type":"Answer","text":"Ya! Kadbod gelombang 100% boleh dikitar semula dan diperbuat daripada serat kayu lestari. Pilihan mesra alam untuk kerajinan."}}]};
const localBusinessSchema = { "@context":"https://schema.org","@type":"Store", name:"Quinocycle Sdn. Bhd.", url:"https://www.quinocycle.com.my", telephone:"+60168916381", address:{"@type":"PostalAddress","streetAddress":"No.13, Jalan Taming P/1, Taming Jaya","addressLocality":"Balakong","addressRegion":"Selangor","postalCode":"43300","addressCountry":"MY"}, geo:{"@type":"GeoCoordinates","latitude":3.0579,"longitude":101.7468}, openingHoursSpecification:[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"18:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"09:00","closes":"13:00"}], priceRange:"RM 1.50 – RM 4.00 setiap kepingan", areaServed:"Semenanjung Malaysia" };
---
<Layout title={post.title} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <article class="max-w-4xl mx-auto px-6 md:px-8 pt-16 pb-24">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-primary/20 text-primary font-label font-bold text-xs uppercase tracking-widest px-3 py-1 rounded-full">{post.category}</span>
        <time class="font-body text-sm text-secondary">{post.date}</time>
      </div>
      <h1 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-4">{post.title}</h1>
      <p class="font-body text-lg text-secondary leading-relaxed">{post.description}</p>
    </header>

    <section class="mb-12">
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Kadbod gelombang bukan hanya untuk pembungkusan penghantaran. Pembuat, artis, dan penggemar DIY di seluruh Malaysia menggunakan kepingan kadbod untuk projek kreatif — daripada perabot kucing hingga instalasi seni hingga perlindungan jentera.
      </p>
      <p class="font-body text-on-surface leading-relaxed">
        Quinocycle membekalkan kadbod gelombang borong untuk pembuat dan pemula kerajinan pada harga mampu.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">1. Projek DIY Popular Menggunakan Kadbod Gelombang</h2>

      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Perabot Haiwan Kesayangan</h3>
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Penggemar kucing dan anjing membuat rumah, tempat tidur, dan pengikis dari kadbod. Tekstur gelombang secara semula jadi menarik kucing. Banyak pemula perniagaan produk haiwan kesayangan bersumber kadbod dari Quinocycle untuk operasi mereka.
      </p>

      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Instalasi Seni & Acara</h3>
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Untuk acara, pasar, dan instalasi sementara, kadbod adalah material ideal — ringan, mudah dipotong, boleh disusun, dan 100% boleh dikitar semula. Pusat komuniti, sekolah, dan perancang acara sering membeli dalam jumlah besar.
      </p>

      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Organisasi & Storan Rumah</h3>
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Pembahagi laci tersuai, penyelaras almari, dan unit storan kadbod adalah projek DIY yang popular dan inovatif. Kadbod memberikan struktur sambil kekal ringan.
      </p>

      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Pemodelan & Prototaip</h3>
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Jurutera, arkitek, dan pembuat menggunakan kadbod untuk prototaip cepat dan model skala. Mudah dipotong, digam, dan diubah suai untuk kerja iteratif.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">2. Memilih Ketebalan yang Betul</h2>

      <div class="space-y-4 mb-6">
        <div class="p-6 bg-primary/5 border border-primary/20 rounded-lg">
          <h4 class="font-bold text-on-surface mb-3">Dinding Tunggal (3–5mm) — Kerajinan Umum</h4>
          <p class="font-body text-on-surface text-sm mb-2">Sesuai untuk: Mainan, seni, hiasan, projek ringan.</p>
          <p class="font-label text-xs text-secondary">Harga: RM 1.50–2.50 setiap kepingan</p>
        </div>

        <div class="p-6 bg-primary/5 border border-primary/20 rounded-lg">
          <h4 class="font-bold text-on-surface mb-3">Dinding Berganda (7–10mm) — Projek Struktural</h4>
          <p class="font-body text-on-surface text-sm mb-2">Sesuai untuk: Perabot, instalasi besar, model yang perlu daya tahan.</p>
          <p class="font-label text-xs text-secondary">Harga: RM 3.00–4.00 setiap kepingan</p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">3. Mula Projek Kadbod Anda Hari Ini</h2>

      <ul class="space-y-3 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">✓</span>
          <span class="font-body text-on-surface">Harga borong: Pesanan 50+ kepingan dapat diskaun</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">✓</span>
          <span class="font-body text-on-surface">Saiz tersuai: Pemotongan khas tersedia</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">✓</span>
          <span class="font-body text-on-surface">Penghantaran cepat: Hari yang sama/berikutnya untuk Selangor</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">✓</span>
          <span class="font-body text-on-surface">Mesra alam: 100% boleh dikitar semula</span>
        </li>
      </ul>
    </section>

    <section class="mb-12 p-8 bg-primary/5 border border-primary/20 rounded-lg">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Pesan Kadbod Gelombang Untuk Kerajinan Anda</h3>
      <p class="font-body text-on-surface leading-relaxed mb-6">
        Pembuat dan pemula di Malaysia boleh memperoleh kadbod gelombang borong dari Quinocycle dengan harga yang kompetitif.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="bg-primary text-on-primary font-bold px-6 py-3 rounded-lg hover:opacity-90 transition text-center">
          WhatsApp untuk Sebut Harga
        </a>
        <a href="tel:+60168916381" class="bg-surface-variant/50 border border-primary/20 text-on-surface font-bold px-6 py-3 rounded-lg hover:bg-surface-variant transition text-center">
          Hubungi +6016-8916381
        </a>
      </div>
      <p class="font-body text-xs text-secondary mt-4">📧 E-mel: quinocycle@gmail.com | 📍 Balakong, Selangor</p>
    </section>

    <section>
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">Kesimpulan</h2>
      <p class="font-body text-on-surface leading-relaxed">
        Kadbod gelombang adalah material yang sangat serba guna untuk kerajinan tangan dan projek DIY. Ia terjangkau, mudah bekerja, dan 100% mesra alam. Sama ada anda adalah pembuat perabot kucing, artis pemasangan, atau pemula perniagaan, Quinocycle menyediakan kadbod gelombang borong berkualiti tinggi dengan harga yang kompetitif dan penghantaran cepat di seluruh Selangor.
      </p>
    </section>
  </article>
</Layout>
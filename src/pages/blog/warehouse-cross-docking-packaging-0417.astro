const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What box sizes are ideal for cross-docking operations?","acceptedAnswer":{"@type":"Answer","text":"Small to medium boxes (20x15cm to 40x30cm) work best for rapid cross-docking. These minimize handling time and optimize truck utilization. Offer multiple sizes to accommodate diverse product shipments."}},{"@type":"Question","name":"How can the right boxes improve cross-docking efficiency?","acceptedAnswer":{"@type":"Answer","text":"Right-sized boxes reduce packing time, improve stackability, and optimize load planning. Standardized boxes speed sorting and routing to final destinations. This improves dock throughput by 15–25%."}},{"@type":"Question","name":"Can I use used carton boxes for cross-docking?","acceptedAnswer":{"@type":"Answer","text":"Yes! Quality checked used boxes save 40–60% cost while maintaining structural integrity. Perfect for high-velocity operations where boxes spend minimal time in the warehouse."}},{"@type":"Question","name":"What quantities should I maintain for cross-docking?","acceptedAnswer":{"@type":"Answer","text":"Keep 3–5 days' inventory of commonly used sizes. Cross-docking's speed means boxes move quickly. Quinocycle's RM 1,000 minimum supports frequent reordering for high-velocity logistics hubs."}},{"@type":"Question","name":"How do I organize boxes for quick access during cross-docking?","acceptedAnswer":{"@type":"Answer","text":"Store boxes on easily accessible racks near packing areas. Organize by size and product type. Minimize walking distance between receiving and shipping docks. Vertical storage maximizes space efficiency."}}]};

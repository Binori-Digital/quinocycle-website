---
import Layout from '../../layouts/Layout.astro';
const post = { title: 'Honeycomb untuk Penghantaran Mesin & Peralatan Industri Malaysia — Perlindungan Premium', description: 'Melindungi mesin industri berharga semasa pengangkutan. Panel honeycomb memberikan perlindungan 3–5× lebih baik daripada kadbod standard dengan berat yang lebih ringan.', date: '2026-04-14', readTime: '7 min', category: 'Kadbod Honeycomb', author: 'Quinocycle Team', slug: 'honeycomb-mesin-penghantaran-industri-0414' };
const WA_LINK = 'https://wa.me/60168916381?text=Hai%20Quinocycle!%20Kami%20perlukan%20honeycomb%20untuk%20penghantaran%20mesin%20industri.%20Boleh%20sediakan%20spesifikasi%20dan%20harga?';
const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-14', dateModified: '2026-04-14', inLanguage: "ms-MY", author: { "@type": "Organization", name: "Quinocycle Team", url: "https://www.quinocycle.com.my" }, publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my" }, mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my" }, keywords: "honeycomb, perlindungan mesin, penghantaran industri, kadbod berat Malaysia" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Berapa banyak perlindungan yang diberikan honeycomb berbanding kadbod standard?","acceptedAnswer":{"@type":"Answer","text":"Honeycomb 3–5× lebih kuat daripada kadbod gelombang standard sambil 50–70% lebih ringan. Ia mengedarkan daya hentaman di atas kawasan yang lebih luas tanpa memindahkan daya ke kandungan."}},{"@type":"Question","name":"Ketebalan honeycomb apa yang diperlukan untuk mesin?","acceptedAnswer":{"@type":"Answer","text":"Untuk mesin, panel 15–25mm adalah tipikal. Panel yang lebih tebal (hingga 40mm) boleh digunakan untuk peralatan yang sangat sensitif. Pilihan bergantung pada berat dan kerapuhan peralatan."}},{"@type":"Question","name":"Boleh honeycomb disesuaikan untuk peralatan unik?","acceptedAnswer":{"@type":"Answer","text":"Ya. Panel boleh dipotong untuk memuatkan dimensi mesin apa pun. Banyak syarikat industri bekerja dengan Quinocycle untuk merancang cangkang perlindungan tersuai."}},{"@type":"Question","name":"Adakah honeycomb lebih mahal daripada kadbod biasa?","acceptedAnswer":{"@type":"Answer","text":"Honeycomb lebih mahal setiap unit tetapi memberikan perlindungan lebih baik, mengurangkan tuntutan kerosakan dan kos insurans. ROI ketara untuk mesin mahal."}},{"@type":"Question","name":"Bagaimana saya mengira panel yang saya perlukan?","acceptedAnswer":{"@type":"Answer","text":"Ukurkan panjang, lebar, dan tinggi mesin anda, kemudian tambahkan 10–15cm keluaran di semua sisi untuk padding. Quinocycle boleh mengira keperluan panel berdasarkan dimensi peralatan anda."}}]};
const localBusinessSchema = { "@context":"https://schema.org","@type":"Store", name:"Quinocycle Sdn. Bhd.", url:"https://www.quinocycle.com.my", telephone:"+60168916381", address:{"@type":"PostalAddress","streetAddress":"No.13, Jalan Taming P/1, Taming Jaya","addressLocality":"Balakong","addressRegion":"Selangor","postalCode":"43300","addressCountry":"MY"}, geo:{"@type":"GeoCoordinates","latitude":3.0579,"longitude":101.7468}, openingHoursSpecification:[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"18:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"09:00","closes":"13:00"}], priceRange:"RM 4.00 – RM 12.00 setiap panel", areaServed:"Semenanjung Malaysia" };
---
<Layout title={post.title} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <article class="max-w-4xl mx-auto px-6 md:px-8 pt-16 pb-24">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-primary/20 text-primary font-label font-bold text-xs uppercase tracking-widest px-3 py-1 rounded-full">{post.category}</span>
        <time class="font-body text-sm text-secondary">{post.date}</time>
      </div>
      <h1 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-4">{post.title}</h1>
      <p class="font-body text-lg text-secondary leading-relaxed">{post.description}</p>
    </header>

    <section class="mb-12">
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Mesin industri mewakili pelaburan besar. Kerosakan semasa pengangkutan boleh bermakna pembaikan mahal dan perpanjangan masa henti. Panel honeycomb memberikan perlindungan superior sambil kekal ringan dan hemat biaya.
      </p>
      <p class="font-body text-on-surface leading-relaxed">
        Panduan ini menunjukkan bagaimana syarikat pengilangan dan logistik di Malaysia menggunakan honeycomb untuk melindungi mesin berharga.
      </p>
    </section>

    <section class="mb-12">

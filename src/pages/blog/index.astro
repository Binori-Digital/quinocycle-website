<script>
  const filterBtns = document.querySelectorAll('.blog-filter-btn');
  const cards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-on-surface', 'text-surface');
        b.classList.add('border', 'border-outline-variant/40', 'text-secondary');
      });
      btn.classList.add('bg-on-surface', 'text-surface');
      btn.classList.remove('border', 'border-outline-variant/40', 'text-secondary');

      const cat = (btn as HTMLElement).dataset.cat;
      cards.forEach(card => {
        const show = cat === 'All' || (card as HTMLElement).dataset.cat === cat;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>

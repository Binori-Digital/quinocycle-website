---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'kedai-kotak-pindah-malaysia',
    category: 'Panduan Pindah Rumah',
    img: '/images/blog-movers-guide.jpg',
    title: 'Kedai Kotak Pindah Malaysia — Quinocycle, Balakong Selangor',
    excerpt: 'Cari kotak pindah rumah murah di Malaysia? Quinocycle Balakong jual kotak kardus baru & terpakai dari RM 0.90/kotak. Senarai lengkap barang penting untuk pindah rumah.',
    date: '2026-04-08',
    readTime: '7 min',
  },
  {
    slug: 'choose-right-carton-box-size',
    category: 'Packaging Tips',
    img: '/images/blog-choose-box-size.jpg',
    title: 'How to Choose the Right Carton Box Size for Your Business',
    excerpt: 'Choosing the wrong box size costs money and damages products. This simple guide helps you size your boxes perfectly.',
    date: '2026-03-15',
    readTime: '5 min',
  },
  {
    slug: 'new-vs-used-carton-boxes',
    category: 'Buyer Guide',
    img: '/images/blog-new-vs-used.jpg',
    title: 'New vs Used Carton Boxes — Which is Right for You?',
    excerpt: 'Used boxes can save you up to 50% on packaging costs. We break down the pros, cons, and when each makes sense.',
    date: '2026-03-08',
    readTime: '4 min',
  },
  {
    slug: 'cut-packaging-costs-online-seller',
    category: 'Business Tips',
    img: '/images/blog-cut-packaging-costs.jpg',
    title: 'How Online Sellers Can Cut Packaging Costs by 40%',
    excerpt: 'Every ringgit saved on packaging is profit. These practical steps will dramatically cut your packing spend.',
    date: '2026-02-28',
    readTime: '6 min',
  },
  {
    slug: 'how-many-boxes-moving-house',
    category: 'Moving Guide',
    img: '/images/blog-movers-guide.jpg',
    title: "Moving House in Malaysia? Here's How Many Boxes You'll Need",
    excerpt: "Most people either run out or end up with far too many boxes. This room-by-room guide gives you the exact numbers.",
    date: '2026-02-18',
    readTime: '5 min',
  },
  {
    slug: 'eco-packaging-used-boxes-business',
    category: 'Sustainability',
    img: '/images/blog-new-vs-used.jpg',
    title: 'Why Recycled Carton Boxes Are Good for Your Business and the Planet',
    excerpt: "Sustainability isn't just good PR — it cuts costs and attracts eco-conscious customers.",
    date: '2026-02-10',
    readTime: '4 min',
  },
];

const categories = ['All', 'Panduan Pindah Rumah', 'Packaging Tips', 'Buyer Guide', 'Business Tips', 'Moving Guide', 'Sustainability'];
---

<Layout
  title="Blog — Quinocycle Packaging Tips & Business Insights"
  description="Practical guides on packaging, carton box selection, moving tips and business cost-cutting. Written for Malaysian retailers, online sellers, movers and logistics companies."
>
  <!-- Hero -->
  <section class="pt-16 pb-16 px-6 md:px-8 max-w-7xl mx-auto">
    <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">Blog</span>
    <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface leading-[0.9] mb-6">
      Packaging tips.<br /><span class="text-primary italic">Business insights.</span>
    </h1>
    <p class="font-body text-xl text-secondary max-w-xl leading-relaxed">
      Practical guides for retailers, online sellers, movers and logistics companies across Malaysia.
    </p>
  </section>

  <!-- Category Filter -->
  <div class="sticky top-[72px] z-40 bg-[#fdf9f0]/90 backdrop-blur-xl border-b border-outline-variant/20">
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-4 flex gap-2 overflow-x-auto no-scrollbar">
      {categories.map(cat => (
        <button
          class={`blog-filter-btn font-headline font-bold text-xs uppercase tracking-widest px-5 py-2 rounded-full whitespace-nowrap transition-all ${
            cat === 'All'
              ? 'bg-on-surface text-surface'
              : 'border border-outline-variant/40 text-secondary hover:text-primary hover:border-primary'
          }`}
          data-cat={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Posts -->
  <section class="max-w-7xl mx-auto px-6 md:px-8 py-16">
    <!-- Featured post -->
    <a href={`/blog/${posts[0].slug}`} class="group grid grid-cols-1 md:grid-cols-2 bg-surface-container-low rounded-3xl overflow-hidden mb-8 editorial-shadow hover:-translate-y-1 transition-transform duration-300">
      <div class="aspect-[4/3] md:aspect-auto overflow-hidden">
        <img
          src={posts[0].img}
          alt={posts[0].title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="p-8 md:p-12 flex flex-col justify-center">
        <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">{posts[0].category}</span>
        <h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tight text-on-surface mb-4 leading-snug group-hover:text-primary transition-colors">{posts[0].title}</h2>
        <p class="font-body text-secondary leading-relaxed mb-6">{posts[0].excerpt}</p>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4 font-label text-xs text-outline">
            <time datetime={posts[0].date}>{new Date(posts[0].date).toLocaleDateString('en-MY', { day:'numeric', month:'long', year:'numeric' })}</time>
            <span>· {posts[0].readTime} read</span>
          </div>
          <span class="inline-flex items-center gap-1 text-primary font-headline font-bold text-sm group-hover:gap-3 transition-all">
            Read <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
          </span>
        </div>
      </div>
    </a>

    <!-- Grid of remaining posts -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="blogGrid">
      {posts.slice(1).map(post => (
        <a href={`/blog/${post.slug}`} class="blog-card group bg-surface rounded-3xl overflow-hidden flex flex-col editorial-shadow hover:-translate-y-1 transition-transform duration-300" data-cat={post.category}>
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={post.img}
              alt={post.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
          <div class="p-6 flex flex-col flex-1">
            <span class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-2 block">{post.category}</span>
            <h3 class="font-headline text-lg font-bold tracking-tight text-on-surface mb-2 leading-snug flex-1 group-hover:text-primary transition-colors">{post.title}</h3>
            <p class="font-body text-sm text-secondary leading-relaxed mb-4 line-clamp-2">{post.excerpt}</p>
            <div class="flex items-center justify-between pt-4 border-t border-outline-variant/20">
              <span class="font-label text-xs text-outline">
                <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-MY', { day:'numeric', month:'short', year:'numeric' })}</time>
                · {post.readTime}
              </span>
              <span class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform" style="font-size:18px;">arrow_forward</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-surface-container-high">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="bg-primary-container rounded-3xl p-10 md:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 relative overflow-hidden">
        <div class="absolute top-0 right-0 opacity-10 pointer-events-none">
          <span class="material-symbols-outlined" style="font-size:180px;">package_2</span>
        </div>
        <div class="lg:w-1/2 relative z-10">
          <span class="font-label text-xs font-bold uppercase tracking-[0.2em] text-on-primary-container/70 mb-3 block">Stay in the Loop</span>
          <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-primary-container mb-4">
            Get packaging tips sent to your WhatsApp.
          </h2>
          <p class="font-body text-on-primary-container/80 leading-relaxed">Follow us on WhatsApp for pricing updates, stock alerts, and practical packaging guides.</p>
        </div>
        <div class="lg:w-auto relative z-10">
          <a
            href="https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20would%20like%20to%20receive%20packaging%20tips%20and%20updates."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-[#25D366] text-white px-10 py-4 rounded-full font-headline font-bold text-sm uppercase tracking-widest hover:bg-[#1ebd5a] transition-colors whitespace-nowrap"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Follow on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.blog-filter-btn');
  const cards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-on-surface', 'text-surface');
        b.classList.add('border', 'border-outline-variant/40', 'text-secondary');
      });
      btn.classList.add('bg-on-surface', 'text-surface');
      btn.classList.remove('border', 'border-outline-variant/40', 'text-secondary');

      const cat = (btn as HTMLElement).dataset.cat;
      cards.forEach(card => {
        const show = cat === 'All' || (card as HTMLElement).dataset.cat === cat;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>

---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'choose-right-carton-box-size',
    category: 'Packaging Tips',
    title: 'How to Choose the Right Carton Box Size for Your Business',
    excerpt: 'Choosing the wrong box size costs money, damages products, and wastes space. This simple guide helps you size your boxes perfectly for every product type.',
    date: '2026-03-15',
    readTime: '5 min',
  },
  {
    slug: 'new-vs-used-carton-boxes',
    category: 'Buyer Guide',
    title: 'New vs Used Carton Boxes — Which is Right for You?',
    excerpt: 'Used boxes can save you up to 50% on packaging costs. But are they right for your business? We break down the pros, cons, and when each option makes sense.',
    date: '2026-03-08',
    readTime: '4 min',
  },
  {
    slug: 'cut-packaging-costs-online-seller',
    category: 'Business Tips',
    title: 'How Online Sellers Can Cut Packaging Costs by 40%',
    excerpt: 'Every ringgit saved on packaging is profit. These practical steps used by Malaysia\'s top Shopee and TikTok Shop sellers will dramatically cut your packing spend.',
    date: '2026-02-28',
    readTime: '6 min',
  },
  {
    slug: 'how-many-boxes-moving-house',
    category: 'Moving Guide',
    title: 'Moving House in Malaysia? Here\'s How Many Boxes You\'ll Need',
    excerpt: 'Most people either run out or end up with far too many boxes. This room-by-room guide gives you the exact numbers — so your move goes smoothly.',
    date: '2026-02-18',
    readTime: '5 min',
  },
  {
    slug: 'eco-packaging-used-boxes-business',
    category: 'Sustainability',
    title: 'Why Recycled Carton Boxes Are Good for Your Business and the Planet',
    excerpt: 'Sustainability isn\'t just good PR — it cuts costs and attracts eco-conscious customers. Here\'s how switching to used boxes helps your bottom line and the environment.',
    date: '2026-02-10',
    readTime: '4 min',
  },
];

const categories = ['All', 'Packaging Tips', 'Buyer Guide', 'Business Tips', 'Moving Guide', 'Sustainability'];
---

<Layout
  title="Blog — Quinocycle Packaging Tips & Business Insights"
  description="Practical guides on packaging, carton box selection, moving tips and business cost-cutting. Written for Malaysian retailers, online sellers, movers and logistics companies."
>
  <!-- Header -->
  <section class="blog-hero">
    <div class="container">
      <div class="section-eyebrow" style="color:rgba(255,255,255,0.5)">Blog</div>
      <h1 class="blog-hero__title">Packaging tips.<br /><span>Business insights.</span></h1>
      <p class="blog-hero__sub">Practical guides for retailers, online sellers, movers and logistics companies across Malaysia.</p>
    </div>
  </section>

  <!-- Category Filter -->
  <div class="blog-filter">
    <div class="container blog-filter__inner">
      {categories.map(cat => (
        <button
          class={`blog-filter__btn ${cat === 'All' ? 'blog-filter__btn--active' : ''}`}
          data-cat={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>

  <!-- Posts Grid -->
  <section class="blog-section">
    <div class="container">
      <!-- Featured post -->
      <a href={`/blog/${posts[0].slug}`} class="blog-featured">
        <div class="blog-featured__img">
          <div class="blog-featured__img-inner" aria-hidden="true">
            <svg viewBox="0 0 80 60" fill="none" width="80"><rect x="5" y="15" width="50" height="42" fill="#F5C400" stroke="#0A0A0A" stroke-width="2"/><path d="M5 15L25 3L75 3L55 15" fill="#D4A900" stroke="#0A0A0A" stroke-width="2"/><path d="M55 15L75 3L75 45L55 57" fill="#B89200" stroke="#0A0A0A" stroke-width="2"/></svg>
          </div>
          <div class="tag tag--dark" style="position:absolute;top:1.5rem;left:1.5rem">{posts[0].category}</div>
        </div>
        <div class="blog-featured__body">
          <div class="blog-featured__meta">
            <time datetime={posts[0].date}>{new Date(posts[0].date).toLocaleDateString('en-MY', { day:'numeric', month:'long', year:'numeric' })}</time>
            <span>·</span>
            <span>{posts[0].readTime} read</span>
          </div>
          <h2 class="blog-featured__title">{posts[0].title}</h2>
          <p class="blog-featured__excerpt">{posts[0].excerpt}</p>
          <span class="blog-featured__cta">
            Read Article
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

      <!-- Rest of posts -->
      <div class="blog-grid" id="blogGrid">
        {posts.slice(1).map((post, i) => (
          <a href={`/blog/${post.slug}`} class="blog-card" data-cat={post.category} style={`--delay:${i*0.07}s`}>
            <div class="blog-card__img-wrap">
              <div class="blog-card__img-placeholder">
                <div class="blog-card__img-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                </div>
              </div>
            </div>
            <div class="blog-card__body">
              <div class="tag tag--yellow" style="font-size:0.62rem">{post.category}</div>
              <h3 class="blog-card__title">{post.title}</h3>
              <p class="blog-card__excerpt">{post.excerpt}</p>
              <div class="blog-card__meta">
                <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-MY', { day:'numeric', month:'short', year:'numeric' })}</time>
                <span>{post.readTime} read</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="blog-cta">
    <div class="container blog-cta__inner">
      <div>
        <div class="section-eyebrow">Stay in the Loop</div>
        <h2 class="blog-cta__title">Get packaging tips<br />sent to your WhatsApp.</h2>
      </div>
      <a
        href="https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20would%20like%20to%20receive%20packaging%20tips%20and%20updates."
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-wa btn-lg"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Follow on WhatsApp
      </a>
    </div>
  </section>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.blog-filter__btn');
  const cards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('blog-filter__btn--active'));
      btn.classList.add('blog-filter__btn--active');

      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const show = cat === 'All' || card.dataset.cat === cat;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
.blog-hero {
  background: var(--bg-base);
  padding-block: clamp(3rem, 6vw, 5rem);
  position: relative;
  overflow: hidden;
}
.blog-hero::before {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(245,196,0,0.07) 0%, transparent 70%);
  pointer-events: none;
  filter: blur(60px);
}
.blog-hero__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--text-1);
  margin-block: 1rem;
  position: relative;
  z-index: 1;
}
.blog-hero__title span { color: var(--yellow); text-shadow: var(--glow-text); }
.blog-hero__sub {
  font-size: 1rem;
  line-height: 1.6;
  color: var(--text-2);
  max-width: 480px;
  position: relative;
  z-index: 1;
}

.blog-filter {
  border-bottom: 1px solid var(--border);
  padding-block: 1rem;
  background: rgba(6,6,8,0.85);
  backdrop-filter: blur(20px);
  position: sticky;
  top: var(--nav-h);
  z-index: 50;
}
.blog-filter__inner {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  overflow-x: auto;
}
.blog-filter__btn {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 100px;
  background: var(--bg-card);
  color: var(--text-2);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.blog-filter__btn:hover { border-color: var(--border-yellow); color: var(--text-1); }
.blog-filter__btn--active {
  background: rgba(245,196,0,0.15);
  border-color: var(--border-yellow-h);
  color: var(--yellow);
}

.blog-section {
  padding-block: clamp(2.5rem, 5vw, 4rem) var(--section-py);
  background: var(--bg-base);
}

/* Featured */
.blog-featured {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 2.5rem;
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.25s var(--ease-out-expo);
}
.blog-featured:hover {
  border-color: var(--border-yellow);
  box-shadow: var(--glow-sm), 0 20px 60px rgba(0,0,0,0.4);
  transform: translateY(-3px);
}
@media (max-width: 768px) {
  .blog-featured { grid-template-columns: 1fr; }
}
.blog-featured__img {
  background: linear-gradient(135deg, rgba(245,196,0,0.15) 0%, rgba(245,196,0,0.05) 100%);
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-right: 1px solid var(--border-yellow);
}
.blog-featured__img-inner { opacity: 0.25; color: var(--yellow); }
.blog-featured__body {
  padding: clamp(2rem, 4vw, 3rem);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1rem;
}
.blog-featured__meta {
  display: flex;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--text-3);
}
.blog-featured__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  line-height: 1.15;
  color: var(--text-1);
  transition: color 0.15s;
}
.blog-featured:hover .blog-featured__title { color: var(--yellow); }
.blog-featured__excerpt {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-2);
}
.blog-featured__cta {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-top: 0.5rem;
  transition: gap 0.15s, text-shadow 0.15s;
}
.blog-featured:hover .blog-featured__cta { gap: 10px; text-shadow: var(--glow-text); }

/* Grid */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
@media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .blog-grid { grid-template-columns: 1fr; } }

.blog-card {
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  backdrop-filter: blur(12px);
  transition: border-color 0.2s, transform 0.25s var(--ease-out-expo), box-shadow 0.2s, background 0.2s;
}
.blog-card:hover {
  border-color: var(--border-yellow);
  transform: translateY(-5px);
  box-shadow: var(--glow-sm), 0 20px 60px rgba(0,0,0,0.4);
  background: var(--bg-card-hov);
}
.blog-card__img-wrap { overflow: hidden; }
.blog-card__img-placeholder {
  height: 160px;
  background: linear-gradient(135deg, rgba(245,196,0,0.08) 0%, rgba(255,255,255,0.03) 100%);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s var(--ease-out-expo);
}
.blog-card:hover .blog-card__img-placeholder { transform: scale(1.04); }
.blog-card__img-icon { color: var(--yellow); opacity: 0.3; }
.blog-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}
.blog-card__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.1rem;
  line-height: 1.2;
  color: var(--text-1);
  transition: color 0.15s;
}
.blog-card:hover .blog-card__title { color: var(--yellow); }
.blog-card__excerpt {
  font-size: 0.84rem;
  line-height: 1.65;
  color: var(--text-2);
  flex: 1;
}
.blog-card__meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: var(--text-3);
  padding-top: 0.75rem;
  border-top: 1px solid var(--border);
}

/* CTA */
.blog-cta {
  background: var(--bg-2);
  padding-block: clamp(3rem, 6vw, 5rem);
  position: relative;
  overflow: hidden;
}
.blog-cta::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 300px;
  background: radial-gradient(ellipse, rgba(245,196,0,0.08) 0%, transparent 70%);
  pointer-events: none;
  filter: blur(50px);
}
.blog-cta__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}
.blog-cta__title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(1.75rem, 3.5vw, 3rem);
  line-height: 1.1;
  color: var(--text-1);
  margin-top: 0.5rem;
}
</style>

  readTime: '7 min',
  category: 'Ilmu Pembungkusan',
  author: 'Quinocycle Team',
  slug: 'jenis-flute-kotak-kardus-panduan-0413',
};
const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20Saya%20ingin%20tahu%20lebih%20lanjut%20tentang%20jenis%20flute%20kotak%20kardus%20untuk%20perniagaan%20saya';
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.date,
  inLanguage: "ms-MY",
  author: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my" },
  publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my", logo: { "@type": "ImageObject", url: "https://www.quinocycle.com.my/images/logo.png" } },
  mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my/blog/jenis-flute-kotak-kardus-panduan-0413" },

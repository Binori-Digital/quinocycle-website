const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "Apakah jenis flute kotak kardus yang paling biasa digunakan di Malaysia?", acceptedAnswer: { "@type": "Answer", text: "Flute B dan flute C adalah yang paling biasa digunakan di Malaysia untuk penghantaran am dan e-dagang. Flute BC dinding berganda digunakan secara meluas untuk barangan berat dan penghantaran industri. Flute A digunakan untuk pembungkusan runcit premium, manakala flute E popular untuk kotak kecil dan pembungkusan dalam." } },
    { "@type": "Question", name: "Apakah maksud dinding tunggal dan dinding berganda dalam kotak bergelombang?", acceptedAnswer: { "@type": "Answer", text: "Papan bergelombang dinding tunggal mempunyai satu lapisan medium bergelombang antara dua lembaran liner rata (3-ply). Dinding berganda mempunyai dua lapisan medium bergelombang dengan tiga lembaran liner (5-ply). Dinding berganda jauh lebih kuat dan lebih tahan terhadap mampatan dan impak." } },
    { "@type": "Question", name: "Flute mana yang terbaik untuk pembungkusan bahagian jentera berat?", acceptedAnswer: { "@type": "Answer", text: "Papan bergelombang BC dinding berganda atau bahkan tiga dinding disyorkan untuk bahagian jentera berat. Flute BC menggabungkan kekakuan flute C dengan rintangan cucukan flute B, menjadikannya sesuai untuk aplikasi industri dengan komponen berat dan bersisi tajam." } },
    { "@type": "Question", name: "Adakah flute E cukup kuat untuk penghantaran e-dagang?", acceptedAnswer: { "@type": "Answer", text: "Flute E (1.5mm) sesuai untuk barangan ringan di bawah 2–3 kg dan penghantaran jarak pendek. Untuk kebanyakan aplikasi e-dagang yang melibatkan produk melebihi 1 kg atau pengendalian kurier berbilang henti, flute B atau C dinding tunggal adalah lebih selamat." } },
    { "@type": "Question", name: "Bolehkah Quinocycle membantu saya memilih flute yang sesuai untuk produk saya?", acceptedAnswer: { "@type": "Answer", text: "Ya. Pasukan Quinocycle di Balakong, Selangor boleh memberi nasihat tentang pembinaan kotak terbaik untuk jenis produk, berat, dan kaedah penghantaran anda. Hubungi kami melalui WhatsApp dengan butiran produk anda dan kami akan mengesyorkan gred kotak yang sesuai." } },
  ]

};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "Are used carton boxes structurally safe for shipping?", acceptedAnswer: { "@type": "Answer", text: "Yes, when graded properly. Quinocycle inspects all used boxes and only stocks those with intact structure, no moisture damage, and sufficient compressive strength for one further shipping cycle. Heavily worn or wet boxes are culled before sale." } },
    { "@type": "Question", name: "How much can an SME save by switching to used carton boxes?", acceptedAnswer: { "@type": "Answer", text: "Typically 30–50% compared to buying new boxes of the same size and grade. For a business spending RM 2,000/month on new boxes, switching to used can save RM 600–1,000 monthly — significant savings over a year." } },
    { "@type": "Question", name: "What is the environmental impact of using secondhand carton boxes?", acceptedAnswer: { "@type": "Answer", text: "Each reused carton box prevents the need for new raw materials (virgin pulp or recycled fibre), reduces energy usage in manufacturing, and keeps usable packaging out of landfill or recycling streams prematurely. It is one of the most direct sustainability wins in logistics." } },
    { "@type": "Question", name: "Do used boxes from Quinocycle come in standard sizes?", acceptedAnswer: { "@type": "Answer", text: "Our used box stock varies — it comes from factories and warehouses. We can advise on current available sizes when you contact us. Common sizes (Small to XL) are usually in stock, though quantities vary by size." } },
    { "@type": "Question", name: "Can I mix used and new boxes in a single order?", acceptedAnswer: { "@type": "Answer", text: "Yes. Many businesses use new boxes for customer-facing deliveries (brand image) and used boxes for internal transfers, B2B shipping, or storage. We can supply both types with a minimum total order of RM 1,000." } },
  ]
};
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  name: "Quinocycle Sdn. Bhd.",
  url: "https://www.quinocycle.com.my",
  telephone: "+60168916381",
  address: { "@type": "PostalAddress", streetAddress: "No.13, Jalan Taming P/1, Taming Jaya", addressLocality: "Balakong", addressRegion: "Selangor", postalCode: "43300", addressCountry: "MY" },
  geo: { "@type": "GeoCoordinates", latitude: 3.0579, longitude: 101.7468 },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "09:00", closes: "18:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "09:00", closes: "13:00" }

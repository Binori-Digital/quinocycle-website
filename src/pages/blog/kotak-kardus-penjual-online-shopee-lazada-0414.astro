---
import Layout from '../../layouts/Layout.astro';
const post = { title: 'Kotak Kardus untuk Penjual Online Shopee & Lazada — Panduan Pembelian Borong di Malaysia', description: 'Penjual e-commerce dan online di Shopee, Lazada perlu kotak kardus berkualiti dengan harga borong. Panduan lengkap memilih saiz dan gred dari Quinocycle Balakong.', date: '2026-04-14', readTime: '7 min', category: 'Kotak Kardus Baru', author: 'Quinocycle Team', slug: 'kotak-kardus-penjual-online-shopee-lazada-0414' };
const WA_LINK = 'https://wa.me/60168916381?text=Hai%20Quinocycle!%20Saya%20penjual%20online%20dan%20perlukan%20kotak%20kardus%20borong.%20Boleh%20berikan%20harga?';
const articleSchema = { "@context":"https://schema.org","@type":"Article", headline: post.title, description: post.description, datePublished: '2026-04-14', dateModified: '2026-04-14', inLanguage: "ms-MY", author: { "@type": "Organization", name: "Quinocycle Team", url: "https://www.quinocycle.com.my" }, publisher: { "@type": "Organization", name: "Quinocycle Sdn. Bhd.", url: "https://www.quinocycle.com.my", logo: { "@type": "ImageObject", url: "https://www.quinocycle.com.my/logo.png" } }, mainEntityOfPage: { "@type": "WebPage", "@id": "https://www.quinocycle.com.my" }, keywords: "kotak kardus penjual online, Shopee, Lazada, kotak pemasan, pembungkusan e-commerce Malaysia" };
const faqSchema = { "@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Berapa saiz kotak yang terbaik untuk penjual online?","acceptedAnswer":{"@type":"Answer","text":"Kebanyakan penjual online guna saiz Kecil (S: 15×12×10cm) dan Sederhana (M: 25×20×15cm). Pilih berdasarkan berat dan dimensi produk anda. Hindari kotak yang terlalu besar untuk mengurangkan kos penghantaran."}},{"@type":"Question","name":"Berapa harga kotak kardus borong di Malaysia?","acceptedAnswer":{"@type":"Answer","text":"Kotak kardus borong berharga RM 1.90–6.50 per kotak bergantung pada saiz dan gred dinding. Pesanan 500+ unit dapat diskaun 10–15%."}},{"@type":"Question","name":"Adakah saya perlu kotak dinding tunggal atau berganda?","acceptedAnswer":{"@type":"Answer","text":"Dinding tunggal (A/B flute) untuk barang ringan (<5kg). Dinding berganda (BC flute) untuk barang rapuh atau lebih berat. Banyak penjual online guna campuran kedua-duanya."}},{"@type":"Question","name":"Berapa lama penghantaran kotak dari Quinocycle?","acceptedAnswer":{"@type":"Answer","text":"Hari yang sama atau hari berikutnya untuk pesanan di Balakong, Cheras, Kajang, dan Lembah Klang. 2–3 hari kerja untuk Semenanjung Malaysia."}},{"@type":"Question","name":"Boleh saya pesan kotak dalam jumlah kecil?","acceptedAnswer":{"@type":"Answer","text":"Ya, pesanan borong bermula dari RM 1,000. Biasanya ini bersamaan 300–500 kotak bergantung pada campuran saiz."}}]};
const localBusinessSchema = { "@context":"https://schema.org","@type":"Store", name:"Quinocycle Sdn. Bhd.", url:"https://www.quinocycle.com.my", telephone:"+60168916381", address:{"@type":"PostalAddress","streetAddress":"No.13, Jalan Taming P/1, Taming Jaya","addressLocality":"Balakong","addressRegion":"Selangor","postalCode":"43300","addressCountry":"MY"}, geo:{"@type":"GeoCoordinates","latitude":3.0579,"longitude":101.7468}, openingHoursSpecification:[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"18:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"09:00","closes":"13:00"}], priceRange:"RM 1.90 – RM 6.50 setiap kotak", areaServed:"Semenanjung Malaysia" };
---
<Layout title={post.title} description={post.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <article class="max-w-4xl mx-auto px-6 md:px-8 pt-16 pb-24">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-primary/20 text-primary font-label font-bold text-xs uppercase tracking-widest px-3 py-1 rounded-full">{post.category}</span>
        <time class="font-body text-sm text-secondary">{post.date}</time>
      </div>
      <h1 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-4">{post.title}</h1>
      <p class="font-body text-lg text-secondary leading-relaxed">{post.description}</p>
    </header>

    <section class="mb-12">
      <p class="font-body text-on-surface leading-relaxed mb-4">
        Penjual online di Shopee, Lazada, dan platform lain memerlukan kotak kardus berkualiti dengan harga borong yang murah. Kos pembungkusan mempengaruhi margin keuntungan — jadi memilih kotak yang tepat adalah penting.
      </p>
      <p class="font-body text-on-surface leading-relaxed">
        Panduan ini membantu penjual e-commerce di Malaysia memilih kotak yang sesuai dan mendapatkan harga terbaik dari Quinocycle.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">1. Memilih Saiz Kotak untuk Produk Anda</h2>

      <div class="bg-surface-variant/50 border border-outline-variant/20 rounded-lg p-6 mb-6">
        <h3 class="font-bold text-on-surface mb-4">Saiz Standard untuk Penjual Online</h3>
        <ul class="space-y-3">
          <li class="flex gap-3">
            <span class="font-bold text-primary">S:</span>
            <span class="font-body text-on-surface">15×12×10 cm — Barang kecil, perhiasan, kosmetik</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary">M:</span>
            <span class="font-body text-on-surface">25×20×15 cm — Pakaian, kasut, mainan</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary">L:</span>
            <span class="font-body text-on-surface">35×28×20 cm — Barang bulk, buku, elektronik</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary">XL:</span>
            <span class="font-body text-on-surface">45×35×25 cm — Pesanan besar, perabot ringan</span>
          </li>
        </ul>
      </div>

      <p class="font-body text-on-surface leading-relaxed">
        Penting: Ukuran kotak mempengaruhi kos penghantaran. Kotak yang terlalu besar akan dikenakan caj dimensi berat. Pilih saiz yang tepat mengikut produk.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">2. Dinding Tunggal vs. Dinding Berganda</h2>

      <div class="grid md:grid-cols-2 gap-6 mb-6">
        <div class="bg-primary/5 border border-primary/20 rounded-lg p-6">
          <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Dinding Tunggal (A/B Flute)</h3>
          <ul class="space-y-2 text-sm text-on-surface mb-4">
            <li>• Harga: RM 1.90–3.00</li>
            <li>• Sesuai untuk: Barang <5kg</li>
            <li>• Kelebihan: Murah, ringan</li>
            <li>• Kelemahan: Perlindungan terhad</li>
          </ul>
        </div>

        <div class="bg-primary/5 border border-primary/20 rounded-lg p-6">
          <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Dinding Berganda (BC Flute)</h3>
          <ul class="space-y-2 text-sm text-on-surface mb-4">
            <li>• Harga: RM 3.50–6.50</li>
            <li>• Sesuai untuk: Barang rapuh/berat</li>
            <li>• Kelebihan: Perlindungan lebih baik</li>
            <li>• Kelemahan: Lebih mahal</li>
          </ul>
        </div>
      </div>

      <p class="font-body text-on-surface leading-relaxed">
        Banyak penjual online bijak menggunakan campuran: dinding tunggal untuk barang ringan (80%), dinding berganda untuk barang rapuh (20%).
      </p>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">3. Mengoptimalkan Kos Pembungkusan</h2>

      <ol class="space-y-4 mb-6">
        <li class="flex gap-4">
          <span class="font-bold text-primary text-lg">1</span>
          <div>
            <h4 class="font-bold text-on-surface mb-2">Pesan dalam Jumlah Besar</h4>
            <p class="font-body text-on-surface text-sm">Pesanan 500+ unit dapat diskaun 10–15%. Jika anda hantar 100+ kotak seminggu, pemesanan borong lebih murah.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-bold text-primary text-lg">2</span>
          <div>
            <h4 class="font-bold text-on-surface mb-2">Standardisasi Saiz</h4>
            <p class="font-body text-on-surface text-sm">Gunakan hanya 2–3 saiz utama daripada 10 saiz berbeza. Ini mengurangkan kos dan memudahkan pengurusan stok.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-bold text-primary text-lg">3</span>
          <div>
            <h4 class="font-bold text-on-surface mb-2">Kurangkan Bahan Pengisi</h4>
            <p class="font-body text-on-surface text-sm">Gunakan kertas kraft bergulung daripada bubble wrap (lebih murah, lebih mesra alam).</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-bold text-primary text-lg">4</span>
          <div>
            <h4 class="font-bold text-on-surface mb-2">Sumber Kotak Terpakai</h4>
            <p class="font-body text-on-surface text-sm">Kotak terpakai berkualiti hanya RM 0.90–1.50 per kotak. Sempurna untuk e-commerce bukan penampilan premium.</p>
          </div>
        </li>
      </ol>
    </section>

    <section class="mb-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">4. Penghantaran Cepat dari Balakong</h2>

      <ul class="space-y-3 mb-6">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">⚡</span>
          <span class="font-body text-on-surface">Hari yang sama atau hari berikutnya untuk Balakong, Cheras, Kajang, Lembah Klang</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">⚡</span>
          <span class="font-body text-on-surface">2–3 hari kerja untuk Semenanjung Malaysia</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">⚡</span>
          <span class="font-body text-on-surface">Pesan via WhatsApp untuk stok mendesak</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold">⚡</span>
          <span class="font-body text-on-surface">Terma pembayaran fleksibel untuk pesanan tetap (RM 1,000 minimum)</span>
        </li>
      </ul>
    </section>

    <section class="mb-12 p-8 bg-primary/5 border border-primary/20 rounded-lg">
      <h3 class="font-headline text-lg font-bold text-on-surface mb-4">Mulakan Pesanan Kotak Anda Hari Ini</h3>
      <p class="font-body text-on-surface leading-relaxed mb-6">
        Penjual online di Shopee, Lazada, dan platform lain dapat memperoleh kotak kardus berkualiti tinggi dengan harga borong terendah dari Quinocycle.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={WA_LINK} target="_blank" rel="noopener noreferrer" class="bg-primary text-on-primary font-bold px-6 py-3 rounded-lg hover:opacity-90 transition text-center">
          WhatsApp untuk Harga
        </a>
        <a href="tel:+60168916381" class="bg-surface-variant/50 border border-primary/20 text-on-surface font-bold px-6 py-3 rounded-lg hover:bg-surface-variant transition text-center">
          Hubungi +6016-8916381
        </a>
      </div>
      <p class="font-body text-xs text-secondary mt-4">📧 E-mel: quinocycle@gmail.com | 📍 Balakong, Selangor</p>
    </section>

    <section>
      <h2 class="font-headline text-2xl font-bold tracking-tight text-on-surface mb-6">Kesimpulan</h2>
      <p class="font-body text-on-surface leading-relaxed">
        Memilih kotak kardus yang tepat adalah kunci untuk mengurangkan kos pembungkusan penjual online. Dengan memahami saiz, gred dinding, dan strategi pembelian, anda dapat jimat 20–30% daripada kos pembungkusan. Quinocycle menyediakan kotak berkualiti tinggi dengan harga borong terbaik di Selangor untuk penjual e-commerce. Mulakan perjalanan anda hari ini.
      </p>
    </section>
  </article>
</Layout>
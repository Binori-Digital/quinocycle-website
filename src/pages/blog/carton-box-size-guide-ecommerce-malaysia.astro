---
import Layout from '../../layouts/Layout.astro';

const post = {
  title: 'Carton Box Size Guide for E-Commerce Malaysia — Which Size Fits Your Product?',
  description: 'Complete carton box size guide for Malaysian e-commerce sellers. Learn standard sizes, how to measure your product, void fill strategies, and cost implications of box sizing.',
  date: '2026-04-11',
  readTime: '9 min',
  category: 'New Carton Boxes',
  author: 'Quinocycle Team',
  slug: 'carton-box-size-guide-ecommerce-malaysia',
};

const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20I%20need%20help%20choosing%20the%20right%20carton%20box%20sizes%20for%20my%20e-commerce%20business.';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,
  "datePublished": post.date,
  "dateModified": post.date,
  "inLanguage": "en-MY",
  "author": { "@type": "Organization", "name": "Quinocycle Sdn. Bhd.", "url": "https://www.quinocycle.com.my" },
  "publisher": { "@type": "Organization", "name": "Quinocycle", "logo": { "@type": "ImageObject", "url": "https://www.quinocycle.com.my/logo.png" } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://www.quinocycle.com.my/blog/${post.slug}` },
  "keywords": "carton box size guide malaysia, e-commerce packaging sizes, small medium large carton box, right box size for shipping, packaging dimensions malaysia, box sizing e-commerce"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are the standard carton box sizes used in Malaysia e-commerce?", "acceptedAnswer": { "@type": "Answer", "text": "Standard sizes in Malaysia are typically: Small (S) 15×10×10cm, Medium (M) 25×20×15cm, Large (L) 35×25×20cm, and Extra Large (XL) 45×35×25cm. These cover approximately 85% of e-commerce shipping needs for clothing, electronics, food, and household items." } },
    { "@type": "Question", "name": "How do I measure my product to choose the right box size?", "acceptedAnswer": { "@type": "Answer", "text": "Measure the length, width, and height of your product in centimetres. Add 2-3cm clearance on all sides to account for protective padding. The box dimensions should be at least 5% larger than your packaged product. This prevents compression damage and allows for void fill materials." } },
    { "@type": "Question", "name": "What are void fill strategies and why are they important?", "acceptedAnswer": { "@type": "Answer", "text": "Void fill strategies include using crumpled kraft paper, bubble wrap, foam peanuts, or air pillows to fill empty space inside the box. Proper void filling prevents items from shifting during transit, reduces damage claims, and maintains professional presentation. Even proper box sizing requires some void fill for protection." } },
    { "@type": "Question", "name": "What problems occur from using oversized boxes?", "acceptedAnswer": { "@type": "Answer", "text": "Oversized boxes increase shipping costs, require more void fill materials, consume excess warehouse storage space, and create poor unboxing experiences. They also increase carbon footprint and may trigger additional courier surcharges. However, boxes too small cause product damage and high return rates." } },
    { "@type": "Question", "name": "How does wrong box sizing affect my e-commerce business costs?", "acceptedAnswer": { "@type": "Answer", "text": "Using consistently wrong-sized boxes can increase packaging costs by 30-50% through excess materials and shipping surcharges. Damage from undersized boxes causes high return rates (typically 15-25% higher than proper sizing). Quinocycle helps optimize sizing to reduce costs while maintaining product protection." } }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "Quinocycle Sdn. Bhd.",
  "description": "Wholesale supplier of new and used carton boxes for e-commerce, moving, and logistics across Peninsular Malaysia.",
  "url": "https://www.quinocycle.com.my",
  "telephone": "+60168916381",
  "address": { "@type": "PostalAddress", "streetAddress": "No.13, Jalan Taming P/1, Taming Jaya", "addressLocality": "Balakong", "addressRegion": "Selangor", "postalCode": "43300", "addressCountry": "MY" },
  "geo": { "@type": "GeoCoordinates", "latitude": 3.0579, "longitude": 101.7468 },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "13:00" }
  ],
  "priceRange": "RM 0.90 – RM 6.50 per box",
  "areaServed": "Peninsular Malaysia"

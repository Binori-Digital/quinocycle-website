const WA_LINK = 'https://wa.me/60168916381?text=Hi%20Quinocycle!%20Saya%20ingin%20bertanya%20tentang%20kotak%20tersuai%20dan%20pembungkusan%20berjenama.';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.description,
  "datePublished": post.date,
  "dateModified": post.date,
  "inLanguage": "ms-MY",
  "author": { "@type": "Organization", "name": "Quinocycle Sdn. Bhd.", "url": "https://www.quinocycle.com.my" },
  "publisher": { "@type": "Organization", "name": "Quinocycle", "logo": { "@type": "ImageObject", "url": "https://www.quinocycle.com.my/logo.png" } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://www.quinocycle.com.my/blog/${post.slug}` },
  "keywords": "kotak tersuai malaysia, pembungkusan berjenama malaysia, custom box supplier, packaging tersuai perniagaan, unboxing experience malaysia, kotak bercetak, jenama pembungkusan, custom packaging malaysia"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Apakah kelebihan menggunakan kotak tersuai untuk perniagaan?", "acceptedAnswer": { "@type": "Answer", "text": "Kotak tersuai meningkatkan pengenalan jenama, membezakan produk anda daripada pesaing, meningkatkan pengalaman pelanggan, dan boleh meningkatkan nilai yang dirasakan produk anda. Pelanggan yang menerima produk dalam pembungkusan yang menarik dan tersuai cenderung untuk membeli lagi dan merekomendasikan kepada orang lain." } },
    { "@type": "Question", "name": "Berapa kos untuk membuat kotak tersuai?", "acceptedAnswer": { "@type": "Answer", "text": "Kos kotak tersuai bergantung pada kuantiti, saiz, dan kerumitan desain. Untuk pesanan besar (1,000+ kotak), kos per unit boleh berkisar dari RM 0.80 hingga RM 3.00 atau lebih. Pesanan kecil akan lebih mahal per unit. Hubungi Quinocycle untuk penawaran harga yang disesuaikan berdasarkan keperluan spesifik anda." } },
    { "@type": "Question", "name": "Apakah industri yang paling mendapat manfaat daripada kotak tersuai?", "acceptedAnswer": { "@type": "Answer", "text": "E-commerce, kosmetik, makanan dan minuman, elektronik, perhiasan, pakaian, dan hadiah adalah industri yang paling mendapat manfaat. Mana-mana perniagaan yang ingin membedakan diri mereka sendiri dan meningkatkan identiti jenama boleh mendapat manfaat daripada kotak tersuai." } },
    { "@type": "Question", "name": "Bagaimana cara mereka bentuk kotak tersuai anda?", "acceptedAnswer": { "@type": "Answer", "text": "Proses merancang kotak tersuai melibatkan beberapa langkah: menentukan saiz dan jenis kotak yang sesuai, merancang grafis dan logo dengan desainer profesional, memilih warna dan bahan yang tepat, dan membuat sampel untuk persetujuan sebelum produksi massal. Quinocycle boleh membantu dalam setiap langkah proses ini." } },
    { "@type": "Question", "name": "Apakah masa penghantaran untuk kotak tersuai?", "acceptedAnswer": { "@type": "Answer", "text": "Masa penghantaran untuk kotak tersuai biasanya 2-4 minggu, bergantung pada kerumitan desain dan jumlah pesanan. Tempahan awal dan perencanaan yang baik adalah penting untuk memastikan kotak tersuai anda tiba tepat pada waktunya untuk peluncuran produk atau musim penjualan yang penting." } }
  ]
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  "name": "Quinocycle Sdn. Bhd.",
  "description": "Pembekal kotak kardus borong — baru dan terpakai — untuk perniagaan, pindah rumah, dan logistik di seluruh Semenanjung Malaysia.",
  "url": "https://www.quinocycle.com.my",
  "telephone": "+60168916381",
  "address": { "@type": "PostalAddress", "streetAddress": "No.13, Jalan Taming P/1, Taming Jaya", "addressLocality": "Balakong", "addressRegion": "Selangor", "postalCode": "43300", "addressCountry": "MY" },
  "geo": { "@type": "GeoCoordinates", "latitude": 3.0579, "longitude": 101.7468 },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "09:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "13:00" }
  ],
  "priceRange": "RM 0.90 – RM 6.50 sekotak",
  "areaServed": "Semenanjung Malaysia"

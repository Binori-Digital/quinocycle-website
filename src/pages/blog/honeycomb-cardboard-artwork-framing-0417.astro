import Layout from '../../layouts/Layout.astro';
const post = { title: 'Honeycomb Cardboard for Artwork & Framing Protection — Safe Transport for Paintings', description: 'Protect fine art during shipping with honeycomb cardboard. Ultra-light yet strong protection for paintings, frames, and canvas. Balakong packaging for Malaysian artists and galleries.', date: '2026-04-17', readTime: '7 min', category: 'Honeycomb Heavy-Duty Cardboard', author: 'Quinocycle Team', slug: 'honeycomb-cardboard-artwork-framing-0417' };
